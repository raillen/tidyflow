## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## See https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
[Rr]eleases/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bbin/
bin/
obj/
gen/
[Ll]og/
[Ll]ogs/

# Visual Studio 2015/2017 cache directories
.vs/
# Uncomment if you have tasks that create the project's static files in wwwroot
#wwwroot/

# MSTest test Results
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-*.xml

# Build Compliance Checker reports
AnalysisReport.sarif

# .NET Core
project.lock.json
project.fragment.lock.json
artifacts/

# StyleCop
StyleCopReport.xml

# Files built by Visual Studio
*_i.c
*_p.c
*_h.h
*.res
*.sbr
*.tlb
*.tli
*.tlh
*.tmp
*.tmp_proj
*.log
*.vspscc
*.vssscc
.buildlog
*.aps
*.pch
*.managed.pdb
*.scc
*.obj
*.winmd
*.idl
*.pdb
*.g.cs
*.g.i.cs

# FolderFlow Data (Local Persistence)
src/FolderFlow.App/Data/

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoFlow.App.ViewModels"
             xmlns:vo="using:AutoFlow.Domain.ValueObjects"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:materialIcons="using:Material.Icons"
             xmlns:lcl="using:AutoFlow.App.Localization"
             x:Class="AutoFlow.App.Views.AutomationView"
             x:DataType="vm:AutomationViewModel">
    
    <Grid ColumnDefinitions="Auto, *">
        <!-- Main Master-Detail TabControl -->
        <TabControl Grid.ColumnSpan="2" TabStripPlacement="Left">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Width" Value="220"/>
                    <Setter Property="Padding" Value="15,12"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </TabControl.Styles>

            <!-- 1. PAINEL DE CONTROLE -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="ViewDashboardOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl ControlPanel}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,20" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{lcl:Lcl RealTimeProcessing}" FontSize="24" FontWeight="Black"/>
                            <TextBlock Text="{Binding ActiveBadgeText}" Opacity="0.5" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel Spacing="30">
                            <!-- Quick Stats Cards -->
                            <Grid ColumnDefinitions="*, *, *">
                                <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="0,0,15,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="CloudSync" Foreground="{DynamicResource AccentColor}" Width="24"/>
                                        <TextBlock Text="Total de Fluxos" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding TotalJobsCount}" FontSize="28" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="15,0,15,0" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1" Opacity="0.9">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="CheckCircleOutline" Foreground="{DynamicResource SuccessColor}" Width="24"/>
                                        <TextBlock Text="Ativos Agora" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding ActiveJobsCount}" FontSize="28" FontWeight="Black" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="15,0,0,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="DatabaseOutline" Foreground="{DynamicResource AccentColor}" Width="24"/>
                                        <TextBlock Text="Processado Hoje" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding TotalDataProcessed}" FontSize="28" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Actions Shortcut -->
                            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <StackPanel Spacing="20">
                                    <TextBlock Text="Ações Rápidas" FontSize="14" FontWeight="Bold" Opacity="0.7"/>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <Button Command="{Binding CreateDirectCopyCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" CornerRadius="8" Padding="20,12">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <material:MaterialIcon Kind="Plus" Width="18"/>
                                                <TextBlock Text="{lcl:Lcl DirectCopy}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CreateWatchFolderCommand}" Theme="{DynamicResource SolidButton}" Classes="Success" CornerRadius="8" Padding="20,12">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <material:MaterialIcon Kind="Plus" Width="18"/>
                                                <TextBlock Text="{lcl:Lcl WatchFolder}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Active Executions Progress -->
                            <StackPanel Spacing="15">
                                <TextBlock Text="Execuções em Andamento" FontSize="14" FontWeight="Bold" Opacity="0.7"/>
                                <ItemsControl ItemsSource="{Binding ActiveExecutions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vo:JobProgressInfo">
                                            <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" Margin="0,0,0,15" 
                                                    BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1.5">
                                                <StackPanel Spacing="15">
                                                    <Grid ColumnDefinitions="*, Auto">
                                                        <StackPanel Spacing="12">
                                                            <TextBlock Text="{Binding JobName}" FontWeight="ExtraBold" FontSize="18" TextTrimming="CharacterEllipsis"/>
                                                            <ProgressBar Value="{Binding TotalPercentage}" Height="8" CornerRadius="4" Foreground="{DynamicResource SuccessColor}"/>
                                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                                <TextBlock Grid.Column="0" Text="{Binding CurrentFile}" FontSize="11" Opacity="0.5" MaxWidth="400" TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding TransferSpeed, Converter={StaticResource FileSizeConverter}, StringFormat='{}{0}/s'}" FontSize="11" FontWeight="Bold"/>
                                                            </Grid>
                                                        </StackPanel>
                                                        <Border Grid.Column="1" VerticalAlignment="Top" Background="{DynamicResource SuccessColor}" CornerRadius="6" Padding="8,3" Margin="15,0,0,0">
                                                            <TextBlock Text="{Binding TotalPercentage, StringFormat={}{0:F0}%}" FontSize="12" FontWeight="Black" Foreground="White"/>
                                                        </Border>
                                                    </Grid>

                                                    <!-- Real-time Rolling Log -->
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="Fluxo de Arquivos" FontSize="10" FontWeight="Bold" Opacity="0.5" HorizontalAlignment="Left"/>
                                                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="10" Padding="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                            <ItemsControl ItemsSource="{Binding RecentFilesLog}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" FontSize="10" FontFamily="Inter" Opacity="0.8" Margin="0,0,0,3"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Border IsVisible="{Binding !ActiveExecutions.Count}" Padding="60" Opacity="0.2">
                                    <StackPanel HorizontalAlignment="Center" Spacing="15">
                                        <material:MaterialIcon Kind="Sleep" Width="48" Height="48" HorizontalAlignment="Center"/>
                                        <TextBlock Text="Nenhum processo ativo no momento." HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 2. WATCHERS -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="Radar" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Watchers}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,15" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{lcl:Lcl Watchers}" FontSize="20" FontWeight="Black"/>
                                <TextBlock Text="Monitoramento de pastas em tempo real" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CreateWatchFolderCommand}" Classes="Success" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon Kind="Plus" Width="16"/>
                                    <TextBlock Text="{lcl:Lcl WatchFolder}" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding WatchJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:JobItemViewModel">
                                        <Border Classes="JobCard" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="15" Margin="0,0,0,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                                                    <Button Grid.Column="0" Command="{Binding ToggleExpandCommand}" Classes="Tertiary" Padding="4" Margin="0,0,10,0" VerticalAlignment="Center">
                                                        <material:MaterialIcon Kind="{Binding IsExpanded, Converter={StaticResource BoolToIconConverter}, ConverterParameter='ChevronUp|ChevronDown'}" Width="20" Opacity="0.5"/>
                                                    </Button>
                                                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#1A4CAF50" Margin="0,0,15,0">
                                                        <material:MaterialIcon Kind="Radar" Foreground="#4CAF50" Width="22"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Job.Name}" FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                            <Border IsVisible="{Binding IsFinished}" Background="{DynamicResource SuccessColor}" CornerRadius="4" Padding="6,1" VerticalAlignment="Center" Opacity="0.8">
                                                                <TextBlock Text="Finalizado" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LocalizedStatus}" FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                                        <Button Command="{Binding SimulateCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6" ToolTip.Tip="Simular (Dry-Run)" IsEnabled="{Binding !IsSimulating}"><material:MaterialIcon Kind="Binoculars" Width="16" Opacity="0.6"/></Button>
                                                        <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Pencil" Width="16" Opacity="0.6"/></Button>
                                                        <Button Command="{Binding RunNowCommand}" Theme="{DynamicResource SolidButton}" Classes="Success" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Play" Width="16"/></Button>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Expanded Info -->
                                                <StackPanel IsVisible="{Binding IsExpanded}" Spacing="12" Margin="44,5,0,0">
                                                    <Separator Height="1" Background="{DynamicResource CardBorderBrush}" Opacity="0.3"/>
                                                    
                                                    <Grid ColumnDefinitions="*, *, *">
                                                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                                                            <TextBlock Text="Origem" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding Job.SourcePath}" FontSize="11" TextWrapping="Wrap" MaxLines="2"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,10,0">
                                                            <TextBlock Text="Destino" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding Job.TargetPath}" FontSize="11" TextWrapping="Wrap" MaxLines="2"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="4">
                                                            <TextBlock Text="Última Execução" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding LastRunDate, StringFormat={}{0:dd/MM/yyyy HH:mm}, FallbackValue='Nunca'}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Execution Summary -->
                                                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="8" Padding="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="*, *, *">
                                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding CopiedCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Copiados" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding IgnoredCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Ignorados" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding ErrorCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource DangerColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Erros" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="Log de Processamento" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="8" Padding="10" MinHeight="60">
                                                            <ItemsControl ItemsSource="{Binding RecentFilesLog}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" FontSize="10" Opacity="0.8" Margin="0,0,0,2"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border IsVisible="{Binding !WatchJobs.Count}" Padding="60" Opacity="0.2">
                                <StackPanel HorizontalAlignment="Center" Spacing="15">
                                    <material:MaterialIcon Kind="Radar" Width="48" Height="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{lcl:Lcl NoWatchers}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 3. TRANSFERS -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="FileMoveOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Transfers}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,15" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{lcl:Lcl Transfers}" FontSize="20" FontWeight="Black"/>
                                <TextBlock Text="Cópias manuais, sincronização e agendamentos" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CreateDirectCopyCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon Kind="Plus" Width="16"/>
                                    <TextBlock Text="{lcl:Lcl DirectCopy}" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding DirectJobs}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:JobItemViewModel">
                                        <Border Classes="JobCard" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="15" Margin="0,0,0,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <StackPanel Spacing="10">
                                                <Grid ColumnDefinitions="Auto, Auto, *, Auto">
                                                    <Button Grid.Column="0" Command="{Binding ToggleExpandCommand}" Classes="Tertiary" Padding="4" Margin="0,0,10,0" VerticalAlignment="Center">
                                                        <material:MaterialIcon Kind="{Binding IsExpanded, Converter={StaticResource BoolToIconConverter}, ConverterParameter='ChevronUp|ChevronDown'}" Width="20" Opacity="0.5"/>
                                                    </Button>
                                                    <Border Grid.Column="1" Width="44" Height="44" CornerRadius="10" Background="#1A2196F3" Margin="0,0,15,0">
                                                        <material:MaterialIcon Kind="FileMoveOutline" Foreground="#2196F3" Width="22"/>
                                                    </Border>
                                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                                            <TextBlock Text="{Binding Job.Name}" FontWeight="Bold" FontSize="15" TextTrimming="CharacterEllipsis"/>
                                                            <Border IsVisible="{Binding IsFinished}" Background="{DynamicResource SuccessColor}" CornerRadius="4" Padding="6,1" VerticalAlignment="Center" Opacity="0.8">
                                                                <TextBlock Text="Finalizado" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                            </Border>
                                                        </StackPanel>
                                                        <TextBlock Text="{Binding LocalizedStatus}" FontSize="11" Opacity="0.5"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8">
                                                        <Button Command="{Binding SimulateCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6" ToolTip.Tip="Simular (Dry-Run)" IsEnabled="{Binding !IsSimulating}"><material:MaterialIcon Kind="Binoculars" Width="16" Opacity="0.6"/></Button>
                                                        <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Pencil" Width="16" Opacity="0.6"/></Button>
                                                        <Button Command="{Binding RunNowCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Play" Width="16"/></Button>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Expanded Info -->
                                                <StackPanel IsVisible="{Binding IsExpanded}" Spacing="12" Margin="44,5,0,0">
                                                    <Separator Height="1" Background="{DynamicResource CardBorderBrush}" Opacity="0.3"/>
                                                    
                                                    <Grid ColumnDefinitions="*, *, *">
                                                        <StackPanel Grid.Column="0" Spacing="4" Margin="0,0,10,0">
                                                            <TextBlock Text="Origem" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding Job.SourcePath}" FontSize="11" TextWrapping="Wrap" MaxLines="2"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="1" Spacing="4" Margin="0,0,10,0">
                                                            <TextBlock Text="Destino" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding Job.TargetPath}" FontSize="11" TextWrapping="Wrap" MaxLines="2"/>
                                                        </StackPanel>
                                                        <StackPanel Grid.Column="2" Spacing="4">
                                                            <TextBlock Text="Última Execução" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                            <TextBlock Text="{Binding LastRunDate, StringFormat={}{0:dd/MM/yyyy HH:mm}, FallbackValue='Nunca'}" FontSize="11"/>
                                                        </StackPanel>
                                                    </Grid>

                                                    <!-- Execution Summary -->
                                                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="8" Padding="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                                        <Grid ColumnDefinitions="*, *, *">
                                                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding CopiedCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Copiados" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding IgnoredCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Ignorados" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                                                <TextBlock Text="{Binding ErrorCount}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource DangerColor}" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="Erros" FontSize="9" Opacity="0.6" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>

                                                    <StackPanel Spacing="5">
                                                        <TextBlock Text="Log de Processamento" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="8" Padding="10" MinHeight="60">
                                                            <ItemsControl ItemsSource="{Binding RecentFilesLog}">
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <TextBlock Text="{Binding}" FontSize="10" Opacity="0.8" Margin="0,0,0,2"/>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Border>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border IsVisible="{Binding !DirectJobs.Count}" Padding="60" Opacity="0.2">
                                <StackPanel HorizontalAlignment="Center" Spacing="15">
                                    <material:MaterialIcon Kind="FileMoveOutline" Width="48" Height="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{lcl:Lcl NoTransfers}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoFlow.App.ViewModels"
             xmlns:interfaces="using:AutoFlow.Application.Interfaces"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:AutoFlow.App.Localization"
             x:Class="AutoFlow.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <StackPanel Spacing="25" Margin="30, 0, 30, 0">
            <!-- Header & Filters -->
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="{lcl:Lcl Greeting}" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock Text="{lcl:Lcl ControlPanel}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="{lcl:Lcl SystemOverview}" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="15,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="FilterVariant" Width="16" Height="16" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="{lcl:Lcl Type}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableTypes}" SelectedItem="{Binding SelectedTypeFilter}" Width="130" Height="32" CornerRadius="6"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="ClipboardListOutline" Width="16" Height="16" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="{lcl:Lcl Task}" VerticalAlignment="Center" FontSize="12" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding AvailableTasks}" SelectedItem="{Binding SelectedTaskFilter}" Width="160" Height="32" CornerRadius="6"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Metrics Cards Row -->
            <Grid ColumnDefinitions="*, *, *, *">
                <!-- Health Score Card -->
                <Border Grid.Column="0" Margin="0,0,10,0" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto, *">
                            <material:MaterialIcon Grid.Column="0" Kind="HeartPulse" Foreground="{DynamicResource SuccessColor}" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="{lcl:Lcl SystemHealth}" VerticalAlignment="Center" Margin="8,0" FontSize="10" FontWeight="Bold" Opacity="0.6"/>
                        </Grid>
                        <StackPanel HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding HealthStatus}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding HealthScore, StringFormat='{}{0:F1}%'}" FontSize="12" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                        <ProgressBar Value="{Binding HealthScore}" Height="4" CornerRadius="2" Foreground="{DynamicResource SuccessColor}"/>
                    </StackPanel>
                </Border>

                <!-- Data Volume Card -->
                <Border Grid.Column="1" Margin="5,0,5,0" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto, *">
                            <material:MaterialIcon Grid.Column="0" Kind="DatabaseOutline" Foreground="{DynamicResource AccentColor}" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="{lcl:Lcl TotalVolume}" VerticalAlignment="Center" Margin="8,0" FontSize="10" FontWeight="Bold" Opacity="0.6"/>
                        </Grid>
                        <StackPanel HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding TotalDataVolume}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{lcl:Lcl ProcessedData}" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Time Saved Card -->
                <Border Grid.Column="2" Margin="5,0,5,0" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto, *">
                            <material:MaterialIcon Grid.Column="0" Kind="TimerOutline" Foreground="{DynamicResource WarningColor}" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="{lcl:Lcl TimeSaved}" VerticalAlignment="Center" Margin="8,0" FontSize="10" FontWeight="Bold" Opacity="0.6"/>
                        </Grid>
                        <StackPanel HorizontalAlignment="Center" Margin="0,5">
                            <TextBlock Text="{Binding TimeSaved}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>
                            <TextBlock Text="{lcl:Lcl AutomatedWork}" FontSize="11" Opacity="0.6" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Processed Files Summary -->
                <Border Grid.Column="3" Margin="10,0,0,0" Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <Grid ColumnDefinitions="Auto, *">
                            <material:MaterialIcon Grid.Column="0" Kind="Files" Foreground="{DynamicResource AccentColor}" Width="20" Height="20"/>
                            <TextBlock Grid.Column="1" Text="{lcl:Lcl Files}" VerticalAlignment="Center" Margin="8,0" FontSize="10" FontWeight="Bold" Opacity="0.6"/>
                        </Grid>
                        <Grid ColumnDefinitions="*, *, *">
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalProcessed}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/>
                                <TextBlock Text="{lcl:Lcl SuccessBadge}" FontSize="9" Opacity="0.6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalIgnored}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource WarningColor}"/>
                                <TextBlock Text="{lcl:Lcl IgnoredBadge}" FontSize="9" Opacity="0.6"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding TotalErrors}" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource DangerColor}"/>
                                <TextBlock Text="{lcl:Lcl ErrorBadge}" FontSize="9" Opacity="0.6"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Quick Actions -->
            <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="10">
                        <Button Command="{Binding NewDirectCopyCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon Kind="PlusThick" Width="16" Height="16"/>
                                <TextBlock Text="{lcl:Lcl DirectCopy}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding NewWatchFolderCommand}" Classes="Success" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon Kind="Radar" Width="16" Height="16"/>
                                <TextBlock Text="{lcl:Lcl WatchFolder}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding ViewHistoryCommand}" Classes="Secondary" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon Kind="History" Width="16" Height="16"/>
                                <TextBlock Text="{lcl:Lcl History}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                         <Button Command="{Binding ToggleAllJobsCommand}" Classes="Danger" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="12,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <material:MaterialIcon Kind="PauseOctagon" Width="16" Height="16"/>
                                <TextBlock Text="{lcl:Lcl PauseAll}" FontSize="12"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding OpenLogFolderCommand}" Classes="Secondary" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="12,8">
                            <material:MaterialIcon Kind="FolderOpenOutline" Width="16" Height="16"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Lower Section: Activity & System Monitor -->
            <Grid ColumnDefinitions="*, 350" Height="450">
                <Grid Grid.Column="0" RowDefinitions="*, *">
                    <!-- Recent Activities -->
                    <Border Grid.Row="0" Margin="0,0,10,10" Background="{DynamicResource SidebarBackground}" CornerRadius="16" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <Grid RowDefinitions="Auto, *">
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="History" Width="18" Height="18" Foreground="{DynamicResource AccentColor}"/>
                                    <TextBlock Text="{lcl:Lcl RecentActivities}" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                </StackPanel>
                            </Border>
                            <ScrollViewer Grid.Row="1">
                                <ItemsControl ItemsSource="{Binding RecentActivities}" Margin="10">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="interfaces:SystemActivity">
                                            <Border Margin="0,0,0,5" Padding="8" Background="{DynamicResource CardBackground}" CornerRadius="6">
                                                <Grid ColumnDefinitions="70, *">
                                                    <TextBlock Grid.Column="0" Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss}'}" FontSize="10" Opacity="0.5" VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Message}" FontSize="11" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Radar de Agendamentos (NOVO) -->
                    <Border Grid.Row="1" Margin="0,10,10,0" Background="{DynamicResource SidebarBackground}" CornerRadius="16" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <Grid RowDefinitions="Auto, *">
                            <Border Grid.Row="0" Padding="15,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Radar" Width="18" Height="18" Foreground="{DynamicResource SuccessColor}"/>
                                    <TextBlock Text="{lcl:Lcl UpcomingRadar}" FontSize="11" FontWeight="Bold" LetterSpacing="1"/>
                                </StackPanel>
                            </Border>
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding UpcomingJobs}" Margin="15">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="interfaces:UpcomingJobInfo">
                                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,12">
                                            <StackPanel Grid.Column="0" Spacing="2">
                                                <TextBlock Text="{Binding JobName}" FontSize="13" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding NextRun, StringFormat='{}{0:dd/MM HH:mm}'}" FontSize="10" Opacity="0.5"/>
                                            </StackPanel>
                                            <Border Grid.Column="1" Background="{DynamicResource SuccessColor}" Opacity="0.1" CornerRadius="12" Padding="10,4">
                                                <TextBlock Text="{Binding TimeRemaining}" Foreground="{DynamicResource SuccessColor}" FontSize="11" FontWeight="Bold"/>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </Border>
                </Grid>

                <!-- System Monitor -->
                <Border Grid.Column="1" Margin="10,0,0,0" Background="{DynamicResource SidebarBackground}" CornerRadius="16" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <Grid RowDefinitions="Auto, *">
                        <Border Grid.Row="0" Padding="20,15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <material:MaterialIcon Kind="Monitor" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                                <TextBlock Text="{lcl:Lcl SystemMonitor}" FontSize="13" FontWeight="Bold" LetterSpacing="1"/>
                            </StackPanel>
                        </Border>
                        <StackPanel Grid.Row="1" Margin="20" Spacing="25">
                            <!-- Transfer Speed with Graph (NOVO) -->
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="{lcl:Lcl CopySpeed}" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Grid.Column="1" Text="{Binding TransferSpeed}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                </Grid>
                                
                                <!-- Sparkline Graph -->
                                <Border Height="60" Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="2" ClipToBounds="True">
                                    <ItemsControl ItemsSource="{Binding PerformancePoints}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Width="3" Margin="1,0" VerticalAlignment="Bottom" Background="{DynamicResource AccentColor}" CornerRadius="1">
                                                    <Border.Height>
                                                        <Binding Converter="{StaticResource SpeedToHeightConverter}"/> 
                                                    </Border.Height>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </StackPanel>

                            <!-- CPU -->
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="{lcl:Lcl Processor}" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Grid.Column="1" Text="{Binding CpuUsage, StringFormat='{}{0:F1}%'}" FontSize="12" FontWeight="Bold"/>
                                </Grid>
                                <ProgressBar Value="{Binding CpuUsage}" Maximum="100" Height="8" CornerRadius="4" Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>

                            <!-- RAM -->
                            <StackPanel Spacing="10">
                                <Grid ColumnDefinitions="*, Auto">
                                    <TextBlock Grid.Column="0" Text="{lcl:Lcl Ram}" FontSize="12" Opacity="0.7"/>
                                    <TextBlock Grid.Column="1" Text="{Binding RamUsage}" FontSize="12" FontWeight="Bold"/>
                                </Grid>
                                <ProgressBar Value="30" Height="8" CornerRadius="4" Foreground="{DynamicResource SuccessColor}"/>
                            </StackPanel>

                            <!-- Cloud Sync -->
                            <Border Background="{DynamicResource CardBackground}" CornerRadius="10" Padding="15">
                                <Grid ColumnDefinitions="Auto, *">
                                    <material:MaterialIcon Kind="CloudCheck" Width="24" Height="24" Foreground="{DynamicResource SuccessColor}"/>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{lcl:Lcl CloudSync}" FontSize="11" Opacity="0.6"/>
                                        <TextBlock Text="{Binding CloudSyncStatus}" FontSize="13" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoFlow.App.ViewModels"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:lcl="using:AutoFlow.App.Localization"
        xmlns:conv="using:AutoFlow.App.Converters"
        x:Class="AutoFlow.App.Views.BlueprintEditorWindow"
        x:DataType="vm:BlueprintEditorViewModel"
        Title="{lcl:Lcl NewBlueprintTitle}"
        Width="{Binding WindowWidth}" Height="800"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackground}">

    <Window.Styles>
        <Style Selector="Button.TokenChip">
            <Setter Property="Background" Value="{DynamicResource SidebarBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>
        <Style Selector="Button.TokenChip:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>

        <Style Selector="Button.ModifierBtn">
            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
        </Style>

        <Style Selector="Button.HelpBtn">
            <Setter Property="Theme" Value="{DynamicResource TransparentButton}"/>
            <Setter Property="Padding" Value="2"/>
            <Setter Property="Opacity" Value="0.5"/>
        </Style>
        <Style Selector="Button.HelpBtn:pointerover">
            <Setter Property="Opacity" Value="1"/>
        </Style>
    </Window.Styles>

    <Panel>
        <Border Background="{DynamicResource AppBackground}" Opacity="0.95"/>
        
        <Grid ColumnDefinitions="*, Auto" Margin="30">
            <!-- MAIN CONTENT (LEFT) -->
            <Grid Grid.Column="0" RowDefinitions="Auto, *, Auto" Margin="0,0,20,0">
                <!-- Header -->
                <StackPanel Grid.Row="0" Spacing="5" Margin="0,0,0,25">
                    <Grid ColumnDefinitions="*, Auto">
                        <StackPanel>
                            <TextBlock Text="{lcl:Lcl ConfigureAutomation}" FontSize="24" FontWeight="Black"/>
                            <TextBlock Text="{lcl:Lcl BlueprintDesc}" FontSize="13" Opacity="0.6"/>
                        </StackPanel>
                        <Border Grid.Column="1" Background="{DynamicResource AccentColor}" Opacity="0.1" CornerRadius="8" Padding="12,5">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                 <material:MaterialIcon Kind="FileDocumentOutline" Width="16"/>
                                 <TextBlock Text="{Binding IsFolderType, Converter={StaticResource BoolToTextConverter}, ConverterParameter='FOLDER:FILE'}" FontWeight="Black" FontSize="12"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Scrollable Content -->
                <ScrollViewer Grid.Row="1">
                    <StackPanel Spacing="25">
                        <!-- Basic Info -->
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="15">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl JobName}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <TextBox Text="{Binding Name}" Watermark="{lcl:Lcl JobNameWatermark}"/>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl PathToOrganize}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Text="{Binding Path}" CornerRadius="8,0,0,8"/>
                                        <Button Grid.Column="1" Command="{Binding BrowsePathCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Content="{lcl:Lcl Browse}" CornerRadius="0,8,8,0"/>
                                    </Grid>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding IsActive}" Content="{lcl:Lcl EnableOrganization}"/>
                            </StackPanel>
                        </Border>

                        <!-- Renaming & Ultimate Preview -->
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel>
                                        <TextBlock Text="{lcl:Lcl IdentityHeader}" FontSize="14" FontWeight="Bold"/>
                                        <TextBlock Text="{lcl:Lcl RenamingDesc}" FontSize="11" Opacity="0.5"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Command="{Binding ToggleToolboxCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Padding="15,5">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <material:MaterialIcon Kind="AutoFix" Width="16"/>
                                            <TextBlock Text="{lcl:Lcl MagicTools}" FontWeight="Black" FontSize="10"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <TextBox Text="{Binding RenameTemplate}" Watermark="{lcl:Lcl RenameTemplateLabel}" CornerRadius="8" FontSize="18" FontWeight="Medium" Background="{DynamicResource SidebarBackground}"/>

                                <!-- FULL PREVIEW AREA -->
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{lcl:Lcl BeforeAfter}" FontSize="10" FontWeight="Black" Opacity="0.4" LetterSpacing="1"/>
                                    <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{Binding IsNameInvalid, Converter={StaticResource BoolToBrushConverter}, ConverterParameter='DangerColor:AccentColor'}" BorderThickness="1" BoxShadow="0 4 15 0 #15000000">
                                        <StackPanel Spacing="15">
                                            <TextBlock Text="{lcl:Lcl StressTestDesc}" FontSize="9" FontWeight="Bold" Opacity="0.3" HorizontalAlignment="Center"/>
                                            
                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{lcl:Lcl OriginalPath}" FontSize="9" FontWeight="Black" Opacity="0.4"/>
                                                <TextBlock Text="{Binding OriginalNamePreview}" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <material:MaterialIcon Kind="ArrowDown" Width="20" Foreground="{DynamicResource AccentColor}" Opacity="0.5"/>

                                            <StackPanel Spacing="5">
                                                <TextBlock Text="{lcl:Lcl ResultPath}" FontSize="9" FontWeight="Black" Foreground="{DynamicResource AccentColor}"/>
                                                <TextBlock Text="{Binding RenamePreview}" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentColor}" TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <Border IsVisible="{Binding IsNameInvalid}" Background="#1AEE4444" CornerRadius="8" Padding="12,8">
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <material:MaterialIcon Kind="AlertCircle" Foreground="{DynamicResource DangerColor}" Width="18"/>
                                                    <TextBlock Text="{Binding ValidationMessage}" Foreground="{DynamicResource DangerColor}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button Command="{Binding CancelCommand}" Content="{lcl:Lcl Cancel}" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="20,10"/>
                    <Button Command="{Binding SaveCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl Save}" CornerRadius="8" Padding="25,10" FontWeight="Bold"/>
                </StackPanel>
            </Grid>

            <!-- TOOLBOX (RIGHT) -->
            <Border Grid.Column="1" IsVisible="{Binding ToolboxVisible}" Width="350" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,0">
                <Grid RowDefinitions="Auto, *">
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,20">
                        <material:MaterialIcon Kind="AutoFix" Foreground="{DynamicResource AccentColor}" Width="20"/>
                        <TextBlock Text="{lcl:Lcl SmartToolbox}" FontWeight="Black" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>

                    <TabControl Grid.Row="1">
                        <!-- TOKENS & COUNTER -->
                        <TabItem Header="{lcl:Lcl ToolboxTokens}">
                            <Grid RowDefinitions="*, Auto">
                                <ScrollViewer Grid.Row="0" Margin="0,10,0,10">
                                    <ItemsControl ItemsSource="{Binding AvailableTokens}">
                                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[Window].((vm:BlueprintEditorViewModel)DataContext).InsertTokenCommand}" CommandParameter="{Binding Token}" Classes="TokenChip" ToolTip.Tip="{Binding Description}">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <material:MaterialIcon Kind="Plus" Width="12"/>
                                                        <TextBlock Text="{Binding Token}"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <Border Grid.Row="1" Background="{DynamicResource SidebarBackground}" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{lcl:Lcl ConfigureCounter}" FontSize="12" FontWeight="Bold"/>
                                        <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{lcl:Lcl CounterStart}" FontSize="10" Opacity="0.5" Margin="0,0,5,2"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="0" Value="{Binding CounterStart}" Minimum="1" Height="32" Margin="0,0,5,0"/>
                                            
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{lcl:Lcl ZerosPadding}" FontSize="10" Opacity="0.5" Margin="5,0,0,2"/>
                                            <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding CounterPadding}" Minimum="1" Maximum="10" Height="32" Margin="5,0,0,0"/>
                                        </Grid>
                                        <Button Command="{Binding InsertCounterCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" HorizontalAlignment="Stretch" Height="32">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <material:MaterialIcon Kind="Plus" Width="14"/>
                                                <TextBlock Text="{lcl:Lcl InsertCounter}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{lcl:Lcl ToolboxStyles}"/>
                                    <Button Classes="HelpBtn">
                                        <material:MaterialIcon Kind="HelpCircleOutline" Width="14"/>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedRight">
                                                <Border Background="{DynamicResource CardBackground}" Padding="15" CornerRadius="8" Width="300">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="{lcl:Lcl StylesGuideTitle}" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                                        <TextBlock Text="{Binding StylesHelp}" FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </TabItem.Header>
                            <StackPanel Spacing="15" Margin="0,10,0,0">
                                <TextBlock Text="{lcl:Lcl QuickStyles}" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                <WrapPanel>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="upper" Classes="ModifierBtn">UPPER</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="lower" Classes="ModifierBtn">lower</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="title" Classes="ModifierBtn">Title Case</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="snake" Classes="ModifierBtn">snake_case</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="camel" Classes="ModifierBtn">camelCase</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="pascal" Classes="ModifierBtn">PascalCase</Button>
                                    <Button Command="{Binding ApplyModifierCommand}" CommandParameter="kebab" Classes="ModifierBtn">kebab-case</Button>
                                </WrapPanel>
                                
                                <Separator Height="1" Background="{DynamicResource CardBorderBrush}"/>
                                
                                <TextBlock Text="{lcl:Lcl ToolboxSubstrings}" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                <Grid ColumnDefinitions="*, Auto, Auto" RowDefinitions="Auto, Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{lcl:Lcl TakeLabel}" VerticalAlignment="Center" FontSize="11" Margin="0,0,0,10"/>
                                    <NumericUpDown Grid.Row="0" Grid.Column="1" Value="{Binding TakeN}" Minimum="1" Width="80" Margin="10,0,10,10"/>
                                    <Button Grid.Row="0" Grid.Column="2" Command="{Binding InsertSubstringCommand}" CommandParameter="take" Classes="ModifierBtn" Margin="0,0,0,10">TAKE</Button>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{lcl:Lcl SkipLabel}" VerticalAlignment="Center" FontSize="11"/>
                                    <NumericUpDown Grid.Row="1" Grid.Column="1" Value="{Binding SkipN}" Minimum="1" Width="80" Margin="10,0"/>
                                    <Button Grid.Row="1" Grid.Column="2" Command="{Binding InsertSubstringCommand}" CommandParameter="skip" Classes="ModifierBtn">SKIP</Button>
                                </Grid>

                                <Separator Height="1" Background="{DynamicResource CardBorderBrush}"/>
                                <TextBlock Text="{lcl:Lcl MagicPresets}" FontSize="10" FontWeight="Bold" Opacity="0.5"/>
                                <ItemsControl ItemsSource="{Binding Presets}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[Window].((vm:BlueprintEditorViewModel)DataContext).ApplyPresetCommand}" CommandParameter="{Binding Template}" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Margin="0,0,0,5">
                                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </TabItem>

                        <TabItem>
                            <TabItem.Header>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{lcl:Lcl ToolboxRegex}"/>
                                    <Button Classes="HelpBtn">
                                        <material:MaterialIcon Kind="HelpCircleOutline" Width="14"/>
                                        <Button.Flyout>
                                            <Flyout Placement="BottomEdgeAlignedRight">
                                                <Border Background="{DynamicResource CardBackground}" Padding="15" CornerRadius="8" Width="300">
                                                    <StackPanel Spacing="10">
                                                        <TextBlock Text="{lcl:Lcl RegexTipsTitle}" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                                        <TextBlock Text="{Binding RegexHelp}" FontSize="11" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </Flyout>
                                        </Button.Flyout>
                                    </Button>
                                </StackPanel>
                            </TabItem.Header>
                            <StackPanel Spacing="15" Margin="0,10,0,0">
                                <Border Background="{DynamicResource SidebarBackground}" CornerRadius="10" Padding="15">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="{lcl:Lcl RegexTutorial}" FontSize="10" Opacity="0.6" TextWrapping="Wrap"/>
                                        <Separator Height="1" Opacity="0.1"/>
                                        <TextBlock Text="{lcl:Lcl RegexTips}" FontSize="10" FontWeight="Bold" Opacity="0.5" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{Binding RegexRecipes}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Command="{Binding $parent[Window].((vm:BlueprintEditorViewModel)DataContext).ApplyRegexRecipeCommand}" CommandParameter="{Binding}" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Margin="0,0,0,8">
                                                <TextBlock Text="{Binding Name}" FontSize="12"/>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </TabItem>

                        <TabItem Header="{lcl:Lcl ToolboxCleanup}">
                            <StackPanel Spacing="12" Margin="0,10,0,0">
                                <Button Command="{Binding ApplyModifierCommand}" CommandParameter="trim" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Content="Trim (Remover espaços pontas)"/>
                                <Button Command="{Binding ApplyModifierCommand}" CommandParameter="no_double_spaces" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Content="{lcl:Lcl CleanDoubleSpaces}"/>
                                <Button Command="{Binding ApplyModifierCommand}" CommandParameter="clean" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Content="{lcl:Lcl CleanSymbols}"/>
                                <Button Command="{Binding ApplyModifierCommand}" CommandParameter="no_spaces" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Content="{lcl:Lcl SpacesToUnderscore}"/>
                            </StackPanel>
                        </TabItem>
                    </TabControl>
                </Grid>
            </Border>
        </Grid>
    </Panel>
</Window>

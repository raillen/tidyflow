<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:lcl="using:AutoFlow.App.Localization"
        x:Class="AutoFlow.App.Views.ChangelogWindow"
        Title="Changelog"
        Icon="/Assets/app-icon.png"
        Width="500" Height="600"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        TransparencyLevelHint="Mica"
        ExtendClientAreaToDecorationsHint="True">

    <Panel>
        <Border Background="{DynamicResource AppBackground}" Opacity="0.8"/>
        
        <Grid RowDefinitions="Auto, *, Auto" Margin="30">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="10" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Spacing="15">
                    <material:MaterialIcon Kind="History" Width="32" Height="32" Foreground="{DynamicResource AccentColor}"/>
                    <TextBlock Text="{lcl:Lcl ChangelogTitle}" FontSize="24" FontWeight="Black"/>
                </StackPanel>
                <TextBlock Text="{lcl:Lcl ChangelogSubtitle}" FontSize="13" Opacity="0.5"/>
                <Separator Background="{DynamicResource CardBorderBrush}" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="0,0,15,0">
                <StackPanel Spacing="25">
                    <!-- v1.4.1 -->
                    <StackPanel Spacing="10">
                        <Border Background="{DynamicResource AccentColor}" HorizontalAlignment="Left" Padding="10,4" CornerRadius="6">
                            <TextBlock Text="v1.4.1 - NAVIGATION &amp; RESPONSIVENESS" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="April 2026" FontSize="11" Opacity="0.4" FontWeight="Bold"/>
                        <TextBlock Text="{lcl:Lcl Changelog_v1_4_1}" TextWrapping="Wrap" LineHeight="20" FontSize="14" />
                    </StackPanel>

                    <!-- v1.4.0 -->
                    <StackPanel Spacing="10">
                        <Border Background="{DynamicResource AccentColor}" HorizontalAlignment="Left" Padding="10,4" CornerRadius="6">
                            <TextBlock Text="v1.4.0 - VISUAL &amp; TYPOGRAPHY" FontSize="11" FontWeight="Bold" Foreground="White"/>
                        </Border>
                        <TextBlock Text="April 2026" FontSize="11" Opacity="0.4" FontWeight="Bold"/>
                        <TextBlock Text="{lcl:Lcl Changelog_v1_4_0}" TextWrapping="Wrap" LineHeight="20" FontSize="14" />
                    </StackPanel>

                    <TextBlock Text="{lcl:Lcl EndRecentHistory}" HorizontalAlignment="Center" Opacity="0.3" FontSize="11" Margin="0,20"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Footer -->
            <Button Grid.Row="2" Content="{lcl:Lcl GotIt}" 
                    Click="CloseClick"
                    HorizontalAlignment="Right" 
                    Theme="{DynamicResource SolidButton}" 
                    Classes="Primary"
                    Padding="30,10" CornerRadius="8" FontWeight="Bold"/>
        </Grid>
    </Panel>
</Window>

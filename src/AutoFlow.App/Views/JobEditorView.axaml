<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AutoFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:enums="using:AutoFlow.Domain.Enums"
             xmlns:lcl="using:AutoFlow.App.Localization"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
             x:Class="AutoFlow.App.Views.JobEditorView"
             x:DataType="vm:JobEditorViewModel">
    
    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, *, Auto" Margin="0" MinHeight="600">
        
        <!-- Header -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackground}" Padding="30,25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="{lcl:Lcl ConfigureAutomation}" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimary}" LetterSpacing="-0.5"/>
                    <TextBlock Text="{lcl:Lcl AutomationRules}" FontSize="14" Foreground="{DynamicResource TextSecondary}" Opacity="0.6"/>
                </StackPanel>
                <Border Grid.Column="1" VerticalAlignment="Center" 
                        Background="{Binding IsWatchMode, Converter={StaticResource PageToColorConverter}, ConverterParameter='TypeBackground'}" 
                        CornerRadius="20" Padding="15,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="{Binding IsWatchMode, Converter={StaticResource BoolToIconConverter}, ConverterParameter='Radar:FileMoveOutline'}" 
                                              Foreground="White" Width="16"/>
                        <TextBlock Text="{Binding WatchModeLabel}" 
                                   Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Navigation Tabs -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="30,15,30,10" Padding="4" Background="{DynamicResource SidebarBackground}" CornerRadius="12">
            <ListBox Name="NavList" SelectedIndex="{Binding #ContentTabs.SelectedIndex}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="10,12"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                    </Style>
                </ListBox.Styles>
                
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="Tune"/><TextBlock Text="{lcl:Lcl General}" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="FilterVariant"/><TextBlock Text="{lcl:Lcl Filters}" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="CalendarClock"/><TextBlock Text="{lcl:Lcl Schedule}" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="ShieldLock"/><TextBlock Text="{lcl:Lcl Security}" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="LightningBolt"/><TextBlock Text="{lcl:Lcl Advanced}" FontSize="11"/></StackPanel></ListBoxItem>
            </ListBox>
        </Border>

        <!-- Tab Content -->
        <TabControl Name="ContentTabs" Grid.Row="2" Grid.Column="0" Margin="0,0,0,20">
            <TabControl.Styles><Style Selector="TabItem"><Setter Property="Header" Value=""/><Setter Property="MinHeight" Value="0"/><Setter Property="Padding" Value="0"/></Style></TabControl.Styles>

            <!-- GERAL -->
            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl JobName}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.Name}" Watermark="{lcl:Lcl JobNameWatermark}" Height="42" CornerRadius="10"/>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl SourcePath}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Text="{Binding SourcePathText}" Height="42" CornerRadius="10,0,0,10" Background="{DynamicResource SidebarBackground}"/>
                                        <Button Grid.Column="1" Command="{Binding SelectSourcePathCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Content="{lcl:Lcl Browse}" Height="42" CornerRadius="0,10,10,0" Padding="15,0"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl DestPath}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Text="{Binding TargetPathText}" Height="42" CornerRadius="10,0,0,10" Background="{DynamicResource SidebarBackground}"/>
                                        <Button Grid.Column="1" Command="{Binding SelectTargetPathCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Content="{lcl:Lcl Browse}" Height="42" CornerRadius="0,10,10,0" Padding="15,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="*, *">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                <TextBlock Text="{lcl:Lcl WorkMode}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding Job.Mode}" HorizontalAlignment="Stretch" CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumLocalizationConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                <TextBlock Text="{lcl:Lcl FileConflicts}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                <ComboBox ItemsSource="{Binding ConflictModes}" SelectedItem="{Binding Job.ConflictMode}" HorizontalAlignment="Stretch" CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumLocalizationConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- FILTROS -->
            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                        <TextBlock Text="{lcl:Lcl IncludeExtensions}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                        <TextBox Text="{Binding ExtensionsText}" Watermark="{lcl:Lcl ExtensionsWatermark}" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                        <TextBlock Text="{lcl:Lcl IgnorePatterns}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                        <TextBox Text="{Binding ExcludePatternsText}" Watermark="{lcl:Lcl IgnoreWatermark}" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl RegexExpression}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.NameRegex}" Watermark="{lcl:Lcl RegexWatermark}" FontFamily="Consolas" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" Opacity="0.8">
                            <UniformGrid Columns="2">
                                <CheckBox IsChecked="{Binding Job.Recursive}" Content="{lcl:Lcl ProcessSubfolders}"/>
                                <CheckBox IsChecked="{Binding Job.SmartSync}" Content="{lcl:Lcl SmartSyncLabel}"/>
                            </UniformGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AGENDA -->
            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border IsVisible="{Binding IsWatchMode}" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Radar" Foreground="{DynamicResource SuccessColor}" Width="20"/>
                                    <TextBlock Text="{lcl:Lcl WatcherConfigs}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                        <TextBlock Text="{lcl:Lcl DetectionMethod}" FontSize="11" Opacity="0.6"/>
                                        <ComboBox ItemsSource="{Binding MonitoringModes}" SelectedItem="{Binding Job.MonitoringMode}" HorizontalAlignment="Stretch" CornerRadius="8">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource EnumLocalizationConverter}}"/>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                        <TextBlock Text="{lcl:Lcl StabilizationTime}" FontSize="11" Opacity="0.6"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Slider Value="{Binding Job.SettleTimeSeconds}" Minimum="1" Maximum="60"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Job.SettleTimeSeconds, StringFormat='{}{0}s'}" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border IsVisible="{Binding !IsWatchMode}" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl ScheduleType}" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <ComboBox ItemsSource="{Binding ScheduleTypes}" SelectedItem="{Binding Job.ScheduleType}" HorizontalAlignment="Stretch" CornerRadius="10">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Converter={StaticResource EnumLocalizationConverter}}"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.None}}" Spacing="20">
                                    <Separator Opacity="0.2"/>
                                    <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.Weekly}}" Spacing="10">
                                        <TextBlock Text="{lcl:Lcl RepeatOnDays}" FontSize="11" Opacity="0.6"/>
                                        <UniformGrid Columns="7">
                                            <ToggleButton Content="{lcl:Lcl Sun}" IsChecked="{Binding IsSun}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Mon}" IsChecked="{Binding IsMon}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Tue}" IsChecked="{Binding IsTue}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Wed}" IsChecked="{Binding IsWed}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Thu}" IsChecked="{Binding IsThu}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Fri}" IsChecked="{Binding IsFri}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="{lcl:Lcl Sat}" IsChecked="{Binding IsSat}" Height="36"/>
                                        </UniformGrid>
                                    </StackPanel>
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="{lcl:Lcl ExecutionTime}" FontSize="11" Opacity="0.6"/>
                                        <Grid ColumnDefinitions="*, *, *">
                                            <NumericUpDown Grid.Column="0" Value="{Binding ScheduleHour}" Minimum="0" Maximum="23" FormatString="00" Margin="0,0,8,0"/>
                                            <NumericUpDown Grid.Column="1" Value="{Binding ScheduleMinute}" Minimum="0" Maximum="59" FormatString="00" Margin="0,0,8,0"/>
                                            <NumericUpDown Grid.Column="2" Value="{Binding ScheduleSecond}" Minimum="0" Maximum="59" FormatString="00"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- SEGURANÇA -->
            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="ShieldLock" Foreground="{DynamicResource SuccessColor}" Width="20"/>
                                    <TextBlock Text="{lcl:Lcl DataProtection}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl EncryptionKeyLabel}" FontSize="11" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.EncryptionKey}" PasswordChar="●" Watermark="{lcl:Lcl EncryptionKeyWatermarkEditor}" CornerRadius="10"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding Job.VerifyHash}" Content="{lcl:Lcl VerifyHashLabel}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- AVANÇADO -->
            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Webhook" Foreground="{DynamicResource AccentColor}" Width="20"/>
                                    <TextBlock Text="{lcl:Lcl JobWebhooks}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox Text="{Binding Job.WebhookUrl}" Watermark="{lcl:Lcl WebhookUrlWatermarkEditor}" CornerRadius="10"/>
                                <ComboBox ItemsSource="{Binding NotificationTriggers}" SelectedItem="{Binding Job.NotifyOn}" HorizontalAlignment="Stretch" CornerRadius="8">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Converter={StaticResource EnumLocalizationConverter}}"/>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- PREVIEW SIDE PANEL -->
        <Border Grid.Row="2" Grid.Column="1" 
                IsVisible="{Binding HasPreview}"
                Width="280" Background="{DynamicResource SidebarBackground}" 
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Margin="25" Spacing="20">
                    <TextBlock Text="{lcl:Lcl SimulationSummary}" FontSize="12" FontWeight="Black" Opacity="0.5" LetterSpacing="1"/>
                    
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="15">
                            <StackPanel>
                                <TextBlock Text="{lcl:Lcl FilesIdentified}" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding CurrentPreview.TotalFiles}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="{lcl:Lcl DataVolume}" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding CurrentPreview.TotalBytes, Converter={StaticResource FileSizeConverter}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{lcl:Lcl SimulationSuccess}" FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                    
                    <Button Command="{Binding ClearPreviewCommand}" Content="{lcl:Lcl ClearPreview}" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackground}" Padding="30,20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GeneratePreviewCommand}" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="EyeOutline" Width="16"/>
                        <TextBlock Text="{lcl:Lcl Simulate}"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding CancelCommand}" Content="{lcl:Lcl Cancel}" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="20,8"/>
                    <Button Command="{Binding SaveCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl SaveAutomation}" CornerRadius="8" Padding="25,8" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoFlow.App.ViewModels"
        xmlns:lcl="using:AutoFlow.App.Localization"
        xmlns:material="using:Material.Icons.Avalonia"
        x:Class="AutoFlow.App.Views.PreviewWindow"
        x:DataType="vm:PreviewWindowViewModel"
        Title="Dry-Run (Simulação)" Width="650" Height="500"
        Icon="/Assets/app-icon.png"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackground}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="-1">

    <Grid RowDefinitions="Auto, *, Auto" Margin="0,30,0,0">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="5">
                <StackPanel Orientation="Horizontal" Spacing="10">
                    <material:MaterialIcon Kind="Binoculars" Width="24" Height="24" Foreground="{DynamicResource PrimaryColor}"/>
                    <TextBlock Text="Resultado da Simulação (Dry-Run)" FontSize="20" FontWeight="Bold"/>
                </StackPanel>
                <TextBlock Text="Nenhum arquivo foi modificado. Este é apenas um relatório do que aconteceria se a tarefa fosse executada agora." FontSize="12" Opacity="0.7" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1" ColumnDefinitions="250, *" Margin="20">
            <StackPanel Grid.Column="0" Spacing="15" Margin="0,0,20,0">
                <Border Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Resumo" FontWeight="Bold" FontSize="14"/>
                        <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Copiar:" Margin="0,5"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding Summary.FilesToCopy}" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}" Margin="0,5"/>
                            
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Mover:" Margin="0,5"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Summary.FilesToMove}" FontWeight="Bold" Foreground="{DynamicResource PrimaryColor}" Margin="0,5"/>
                            
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Ignorar:" Margin="0,5"/>
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Summary.FilesToSkip}" FontWeight="Bold" Foreground="{DynamicResource WarningColor}" Margin="0,5"/>
                            
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Sobrescrever:" Margin="0,5"/>
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Summary.FilesToOverwrite}" FontWeight="Bold" Foreground="{DynamicResource DangerColor}" Margin="0,5"/>
                            
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Volume Total:" Margin="0,5"/>
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding Summary.TotalBytes, Converter={StaticResource FileSizeConverter}}" FontWeight="Bold" Margin="0,5"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <ScrollViewer Padding="15">
                    <ItemsControl ItemsSource="{Binding AffectedPaths}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5" Margin="0,2">
                                    <material:MaterialIcon Kind="FileDocumentOutline" Width="14" Opacity="0.5"/>
                                    <TextBlock Text="{Binding}" FontSize="12" TextWrapping="Wrap"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Footer -->
        <Border Grid.Row="2" Background="{DynamicResource SidebarBackground}" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Button Theme="{DynamicResource SolidButton}" Classes="Primary" Content="Fechar" Width="100" HorizontalAlignment="Right" HorizontalContentAlignment="Center" Command="{Binding $parent[Window].Close}" CornerRadius="8"/>
        </Border>
    </Grid>
</Window>
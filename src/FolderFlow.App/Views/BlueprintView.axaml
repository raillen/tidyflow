<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:FolderFlow.App.Localization"
             x:Class="FolderFlow.App.Views.BlueprintView"
             x:DataType="vm:BlueprintViewModel">
    
    <Grid RowDefinitions="Auto,*">
        <!-- HEADER -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}" Padding="35,30" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="10">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <TextBlock Text="{lcl:Lcl BlueprintHub}" FontSize="34" FontWeight="Black" Foreground="{DynamicResource TextPrimary}" LetterSpacing="-1"/>
                        <Border Background="{DynamicResource AccentColor}" Opacity="0.1" CornerRadius="6" Padding="8,3" VerticalAlignment="Center">
                            <TextBlock Text="{lcl:Lcl Organization}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{lcl:Lcl BlueprintDesc}" FontSize="15" Foreground="{DynamicResource TextSecondary}" Opacity="0.6"/>
                </StackPanel>
                
                <Button Grid.Column="1" Command="{Binding CreateBlueprintCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Height="32" CornerRadius="8" Padding="14,0">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="Plus" Width="16"/>
                        <TextBlock Text="{lcl:Lcl NewBlueprint}" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- CONTENT -->
        <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding AllBlueprints}" Margin="35">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="vm:BlueprintItemViewModel">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <Grid ColumnDefinitions="Auto, *, Auto">
                                <!-- Icon -->
                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#1A888888" Margin="0,0,15,0">
                                    <material:MaterialIcon Kind="FileTree" Foreground="{DynamicResource AccentColor}" Width="22"/>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{Binding Blueprint.Name}" FontWeight="Bold" FontSize="16"/>
                                    <TextBlock Text="{Binding Blueprint.Path}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <ToggleSwitch IsChecked="{Binding Blueprint.IsActive}" Command="{Binding ToggleActiveCommand}" OnContent="" OffContent=""/>
                                    <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6">
                                        <material:MaterialIcon Kind="Pencil" Width="16"/>
                                    </Button>
                                    <Button Command="{Binding DeleteCommand}" Classes="Danger" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6">
                                        <material:MaterialIcon Kind="DeleteOutline" Width="16"/>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</UserControl>

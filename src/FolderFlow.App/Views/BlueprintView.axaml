<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:FolderFlow.App.Localization"
             x:Class="FolderFlow.App.Views.BlueprintView"
             x:DataType="vm:BlueprintViewModel">
    
    <Grid ColumnDefinitions="Auto, *">
        <!-- Main Master-Detail TabControl -->
        <TabControl Grid.ColumnSpan="2" TabStripPlacement="Left">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Width" Value="220"/>
                    <Setter Property="Padding" Value="15,12"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </TabControl.Styles>

            <!-- 1. PAINEL DE CONTROLE -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="ViewDashboardOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl ControlPanel}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,20" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Spacing="5">
                            <TextBlock Text="{lcl:Lcl BlueprintHub}" FontSize="24" FontWeight="Black"/>
                            <TextBlock Text="Visão geral dos modelos de organização" Opacity="0.5" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel Spacing="30">
                            <!-- Stats Cards -->
                            <Grid ColumnDefinitions="*, *, *">
                                <Border Grid.Column="0" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="0,0,15,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="FileTree" Foreground="{DynamicResource AccentColor}" Width="24"/>
                                        <TextBlock Text="Total de Blueprints" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding TotalBlueprintsCount}" FontSize="28" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="15,0,15,0" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1" Opacity="0.9">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="CheckCircleOutline" Foreground="{DynamicResource SuccessColor}" Width="24"/>
                                        <TextBlock Text="Ativos" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding ActiveBlueprintsCount}" FontSize="28" FontWeight="Black" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Background="{DynamicResource CardBackground}" CornerRadius="12" Padding="20" Margin="15,0,0,0" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                    <StackPanel Spacing="10">
                                        <material:MaterialIcon Kind="FileDocumentOutline" Foreground="{DynamicResource AccentColor}" Width="24"/>
                                        <TextBlock Text="Templates de Arquivo" FontSize="12" Opacity="0.6"/>
                                        <TextBlock Text="{Binding FileBlueprintsCount}" FontSize="28" FontWeight="Black"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <!-- Actions Shortcut -->
                            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                <StackPanel Spacing="20">
                                    <TextBlock Text="Ações Rápidas" FontSize="14" FontWeight="Bold" Opacity="0.7"/>
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <Button Command="{Binding CreateFileBlueprintCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" CornerRadius="8" Padding="20,12">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <material:MaterialIcon Kind="Plus" Width="18"/>
                                                <TextBlock Text="{lcl:Lcl NewFileBlueprint}" FontWeight="Bold"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding CreateFolderBlueprintCommand}" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="20,12">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <material:MaterialIcon Kind="Plus" Width="18"/>
                                                <TextBlock Text="{lcl:Lcl NewFolderBlueprint}"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 2. FILES -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="FileDocumentOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl FileOrganization}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,15" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{lcl:Lcl FileOrganization}" FontSize="20" FontWeight="Black"/>
                                <TextBlock Text="Regras de organização para arquivos individuais" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CreateFileBlueprintCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon Kind="Plus" Width="16"/>
                                    <TextBlock Text="{lcl:Lcl NewFileBlueprint}" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding FileBlueprints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BlueprintItemViewModel">
                                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#1A2196F3" Margin="0,0,15,0">
                                                    <material:MaterialIcon Kind="FileDocumentOutline" Foreground="#2196F3" Width="22"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="{Binding Blueprint.Name}" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding Blueprint.Path}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                    <ToggleSwitch IsChecked="{Binding Blueprint.IsActive}" Command="{Binding ToggleActiveCommand}" OnContent="" OffContent=""/>
                                                    <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Pencil" Width="16"/></Button>
                                                    <Button Command="{Binding DeleteCommand}" Classes="Danger" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="DeleteOutline" Width="16"/></Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border IsVisible="{Binding !FileBlueprints.Count}" Padding="60" Opacity="0.2" Background="{DynamicResource CardBackground}" CornerRadius="16">
                                <StackPanel HorizontalAlignment="Center" Spacing="15">
                                    <material:MaterialIcon Kind="FileDocumentOutline" Width="48" Height="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{lcl:Lcl NoFileBlueprints}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- 3. FOLDERS -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="FolderOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl FolderStructure}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <Grid RowDefinitions="Auto, *">
                    <Border Grid.Row="0" Padding="25,15" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{lcl:Lcl FolderStructure}" FontSize="20" FontWeight="Black"/>
                                <TextBlock Text="Regras para criação e manutenção de diretórios" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding CreateFolderBlueprintCommand}" Classes="Success" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <material:MaterialIcon Kind="Plus" Width="16"/>
                                    <TextBlock Text="{lcl:Lcl NewFolderBlueprint}" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" Padding="30">
                        <StackPanel>
                            <ItemsControl ItemsSource="{Binding FolderBlueprints}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BlueprintItemViewModel">
                                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                                            <Grid ColumnDefinitions="Auto, *, Auto">
                                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12" Background="#1A4CAF50" Margin="0,0,15,0">
                                                    <material:MaterialIcon Kind="FolderOutline" Foreground="#4CAF50" Width="22"/>
                                                </Border>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                                    <TextBlock Text="{Binding Blueprint.Name}" FontWeight="Bold" FontSize="16"/>
                                                    <TextBlock Text="{Binding Blueprint.Path}" FontSize="11" Opacity="0.5" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                                    <ToggleSwitch IsChecked="{Binding Blueprint.IsActive}" Command="{Binding ToggleActiveCommand}" OnContent="" OffContent=""/>
                                                    <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="Pencil" Width="16"/></Button>
                                                    <Button Command="{Binding DeleteCommand}" Classes="Danger" Theme="{DynamicResource OutlineButton}" Padding="8" CornerRadius="6"><material:MaterialIcon Kind="DeleteOutline" Width="16"/></Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border IsVisible="{Binding !FolderBlueprints.Count}" Padding="60" Opacity="0.2" Background="{DynamicResource CardBackground}" CornerRadius="16">
                                <StackPanel HorizontalAlignment="Center" Spacing="15">
                                    <material:MaterialIcon Kind="FolderOutline" Width="48" Height="48" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{lcl:Lcl NoFolderBlueprints}" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>

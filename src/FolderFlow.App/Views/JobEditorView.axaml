<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:enums="using:FolderFlow.Domain.Enums"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
             x:Class="FolderFlow.App.Views.JobEditorView"
             x:DataType="vm:JobEditorViewModel">
    
    <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto, *, Auto" Margin="0" MinHeight="600">
        
        <!-- Header -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackground}" Padding="30,25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Configurar Automao" FontSize="28" FontWeight="Black" Foreground="{DynamicResource TextPrimary}" LetterSpacing="-0.5"/>
                    <TextBlock Text="Defina as regras, filtros e destinos para o fluxo de dados" FontSize="14" Foreground="{DynamicResource TextSecondary}" Opacity="0.6"/>
                </StackPanel>
                <Border Grid.Column="1" VerticalAlignment="Center" 
                        Background="{Binding IsWatchMode, Converter={StaticResource PageToColorConverter}, ConverterParameter='TypeBackground'}" 
                        CornerRadius="20" Padding="15,6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="{Binding IsWatchMode, Converter={StaticResource BoolToIconConverter}, ConverterParameter='Radar:FileMoveOutline'}" 
                                              Foreground="White" Width="16"/>
                        <TextBlock Text="{Binding IsWatchMode, Converter={StaticResource EqualsConverter}, ConverterParameter='True:Watch Folder;False:Cpia Direta'}" 
                                   Foreground="White" FontWeight="Bold" FontSize="12"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Navigation Tabs -->
        <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="30,15,30,10" Padding="4" Background="{DynamicResource SidebarBackground}" CornerRadius="12">
            <ListBox Name="NavList" SelectedIndex="{Binding #ContentTabs.SelectedIndex}" Background="Transparent" BorderThickness="0">
                <ListBox.ItemsPanel><ItemsPanelTemplate><UniformGrid Rows="1"/></ItemsPanelTemplate></ListBox.ItemsPanel>
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="10,12"/>
                        <Setter Property="CornerRadius" Value="8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected">
                        <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        <Setter Property="Foreground" Value="{DynamicResource AccentColor}"/>
                    </Style>
                </ListBox.Styles>
                
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="Tune"/><TextBlock Text="Geral" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="FilterVariant"/><TextBlock Text="Filtros" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="CalendarClock"/><TextBlock Text="Agenda" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="ShieldLock"/><TextBlock Text="Segurana" FontSize="11"/></StackPanel></ListBoxItem>
                <ListBoxItem><StackPanel Spacing="5"><material:MaterialIcon Kind="LightningBolt"/><TextBlock Text="Avanado" FontSize="11"/></StackPanel></ListBoxItem>
            </ListBox>
        </Border>

        <!-- Tab Content -->
        <TabControl Name="ContentTabs" Grid.Row="2" Grid.Column="0" Margin="0">
            <TabControl.Styles><Style Selector="TabItem"><Setter Property="Header" Value=""/><Setter Property="MinHeight" Value="0"/><Setter Property="Padding" Value="0"/></Style></TabControl.Styles>

            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Nome da Tarefa" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.Name}" Watermark="Ex: Backup de Documentos" Height="42" CornerRadius="10"/>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Caminho de Origem" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Text="{Binding SourcePathText}" Height="42" CornerRadius="10,0,0,10" Background="{DynamicResource SidebarBackground}"/>
                                        <Button Grid.Column="1" Command="{Binding SelectSourcePathCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Content="Procurar" Height="42" CornerRadius="0,10,10,0" Padding="15,0"/>
                                    </Grid>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Caminho de Destino" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <TextBox Text="{Binding TargetPathText}" Height="42" CornerRadius="10,0,0,10" Background="{DynamicResource SidebarBackground}"/>
                                        <Button Grid.Column="1" Command="{Binding SelectTargetPathCommand}" Theme="{DynamicResource SolidButton}" Classes="Primary" Content="Procurar" Height="42" CornerRadius="0,10,10,0" Padding="15,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Grid ColumnDefinitions="*, *">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                <TextBlock Text="Modo de Trabalho" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding Job.Mode}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                <TextBlock Text="Conflitos de Arquivo" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                <ComboBox ItemsSource="{Binding ConflictModes}" SelectedItem="{Binding Job.ConflictMode}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                        <TextBlock Text="Extenses (Incluso)" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                        <TextBox Text="{Binding ExtensionsText}" Watermark=".jpg, .png, .pdf" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                        <TextBlock Text="Padres a Ignorar" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                        <TextBox Text="{Binding ExcludePatternsText}" Watermark="node_modules, temp" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Expressão Regular (REGEX)" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.NameRegex}" Watermark="Ex: ^[0-9]{4}.*" FontFamily="Consolas" CornerRadius="8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" Opacity="0.8">
                            <UniformGrid Columns="2">
                                <CheckBox IsChecked="{Binding Job.Recursive}" Content="Processar Subpastas"/>
                                <CheckBox IsChecked="{Binding Job.SmartSync}" Content="Smart Sync (Pular idnticos)"/>
                            </UniformGrid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border IsVisible="{Binding IsWatchMode}" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Radar" Foreground="{DynamicResource SuccessColor}" Width="20"/>
                                    <TextBlock Text="CONFIGURAES DO WATCHER" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                        <TextBlock Text="Mtodo de Deteco" FontSize="11" Opacity="0.6"/>
                                        <ComboBox ItemsSource="{Binding MonitoringModes}" SelectedItem="{Binding Job.MonitoringMode}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                        <TextBlock Text="Tempo de Estabilizao" FontSize="11" Opacity="0.6"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <Slider Value="{Binding Job.SettleTimeSeconds}" Minimum="1" Maximum="60"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Job.SettleTimeSeconds, StringFormat='{}{0}s'}" FontWeight="Bold" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>
                        <Border IsVisible="{Binding !IsWatchMode}" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Tipo de Agendamento" FontSize="12" FontWeight="Bold" Opacity="0.6"/>
                                    <ComboBox ItemsSource="{Binding ScheduleTypes}" SelectedItem="{Binding Job.ScheduleType}" HorizontalAlignment="Stretch" CornerRadius="10"/>
                                </StackPanel>
                                <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.None}}" Spacing="20">
                                    <Separator Opacity="0.2"/>
                                    <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.Weekly}}" Spacing="10">
                                        <TextBlock Text="Repetir nos dias:" FontSize="11" Opacity="0.6"/>
                                        <UniformGrid Columns="7">
                                            <ToggleButton Content="D" IsChecked="{Binding IsSun}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="S" IsChecked="{Binding IsMon}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="T" IsChecked="{Binding IsTue}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="Q" IsChecked="{Binding IsWed}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="Q" IsChecked="{Binding IsThu}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="S" IsChecked="{Binding IsFri}" Height="36" Margin="0,0,4,0"/>
                                            <ToggleButton Content="S" IsChecked="{Binding IsSat}" Height="36"/>
                                        </UniformGrid>
                                    </StackPanel>
                                    <StackPanel Spacing="10">
                                        <TextBlock Text="Horrio de Execuo" FontSize="11" Opacity="0.6"/>
                                        <Grid ColumnDefinitions="*, *, *">
                                            <NumericUpDown Grid.Column="0" Value="{Binding ScheduleHour}" Minimum="0" Maximum="23" FormatString="00" Margin="0,0,8,0"/>
                                            <NumericUpDown Grid.Column="1" Value="{Binding ScheduleMinute}" Minimum="0" Maximum="59" FormatString="00" Margin="0,0,8,0"/>
                                            <NumericUpDown Grid.Column="2" Value="{Binding ScheduleSecond}" Minimum="0" Maximum="59" FormatString="00"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="ShieldLock" Foreground="{DynamicResource SuccessColor}" Width="20"/>
                                    <TextBlock Text="PROTEO DE DADOS (AES-256)" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="Chave de Criptografia" FontSize="11" Opacity="0.6"/>
                                    <TextBox Text="{Binding Job.EncryptionKey}" PasswordChar="●" Watermark="Chave para proteger os arquivos no destino" CornerRadius="10"/>
                                </StackPanel>
                                <CheckBox IsChecked="{Binding Job.VerifyHash}" Content="Validar Integridade Ps-Cpia (Hash)"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem>
                <ScrollViewer Padding="30,10,30,30">
                    <StackPanel Spacing="25">
                        <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Webhook" Foreground="{DynamicResource AccentColor}" Width="20"/>
                                    <TextBlock Text="WEBHOOKS DE TAREFA" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox Text="{Binding Job.WebhookUrl}" Watermark="URL especfica para esta tarefa (Opcional)" CornerRadius="10"/>
                                <ComboBox ItemsSource="{Binding NotificationTriggers}" SelectedItem="{Binding Job.NotifyOn}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- PREVIEW SIDE PANEL -->
        <Border Grid.Row="2" Grid.Column="1" 
                IsVisible="{Binding HasPreview}"
                Width="280" Background="{DynamicResource SidebarBackground}" 
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Margin="25" Spacing="20">
                    <TextBlock Text="RESUMO DA SIMULAO" FontSize="12" FontWeight="Black" Opacity="0.5" LetterSpacing="1"/>
                    
                    <Border Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                        <StackPanel Spacing="15">
                            <StackPanel>
                                <TextBlock Text="Arquivos Identificados" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding CurrentPreview.TotalFiles}" FontSize="24" FontWeight="Bold"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock Text="Volume de Dados" FontSize="10" Opacity="0.5"/>
                                <TextBlock Text="{Binding CurrentPreview.TotalBytes, Converter={StaticResource FileSizeConverter}}" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="A simulao foi concluda com sucesso. Os filtros definidos capturaram os dados acima." FontSize="11" Opacity="0.6" TextWrapping="Wrap"/>
                    
                    <Button Command="{Binding ClearPreviewCommand}" Content="Limpar Preview" Theme="{DynamicResource OutlineButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0"/>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- Footer -->
        <Border Grid.Row="3" Grid.ColumnSpan="2" Background="{DynamicResource SidebarBackground}" Padding="30,20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <Button Grid.Column="0" Command="{Binding GeneratePreviewCommand}" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="15,8">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <material:MaterialIcon Kind="EyeOutline" Width="16"/>
                        <TextBlock Text="Simular (Preview)"/>
                    </StackPanel>
                </Button>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12">
                    <Button Command="{Binding CancelCommand}" Content="Cancelar" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="20,8"/>
                    <Button Command="{Binding SaveCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Content="Salvar Automao" CornerRadius="8" Padding="25,8" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>

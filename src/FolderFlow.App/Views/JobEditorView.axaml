<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:enums="using:FolderFlow.Domain.Enums"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="750"
             x:Class="FolderFlow.App.Views.JobEditorView"
             x:DataType="vm:JobEditorViewModel">
    
    <Grid RowDefinitions="*, Auto" Margin="10">
        <TabControl Grid.Row="0" Margin="0" Theme="{StaticResource {x:Type TabControl}}">
            <!-- ABA GERAL -->
            <TabItem Header="Configurações Base">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="15">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Nome da Tarefa" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBox Text="{Binding Job.Name}" Watermark="Ex: Backup Diário SharePoint" Height="36" CornerRadius="8"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" Margin="0,5">
                            <StackPanel Grid.Row="0" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,15">
                                <TextBlock Text="Diretório de Origem" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <DockPanel>
                                    <Button Content="Selecionar" DockPanel.Dock="Right" Command="{Binding SelectSourcePathCommand}" Margin="10,0,0,0" Classes="accent" CornerRadius="8" Height="36"/>
                                    <TextBox Text="{Binding SourcePathText}" Height="36" CornerRadius="8" Background="{DynamicResource CardBackground}"/>
                                </DockPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Spacing="8" Margin="0,0,0,10">
                                <TextBlock Text="Diretório de Destino" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <DockPanel>
                                    <Button Content="Selecionar" DockPanel.Dock="Right" Command="{Binding SelectTargetPathCommand}" Margin="10,0,0,0" Classes="accent" CornerRadius="8" Height="36"/>
                                    <TextBox Text="{Binding TargetPathText}" Height="36" CornerRadius="8" Background="{DynamicResource CardBackground}"/>
                                </DockPanel>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="2">
                            <StackPanel Spacing="8" Margin="0,0,10,0">
                                <TextBlock Text="Modo de Operação" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding Job.Mode}" HorizontalAlignment="Stretch" Height="36" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="Política de Conflito" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                <ComboBox ItemsSource="{Binding ConflictModes}" SelectedItem="{Binding Job.ConflictMode}" HorizontalAlignment="Stretch" Height="36" CornerRadius="8"/>
                            </StackPanel>
                        </UniformGrid>

                        <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="15">
                            <CheckBox IsChecked="{Binding Job.Recursive}" Content="Processar subdiretórios recursivamente" FontWeight="Medium"/>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ABA FILTROS -->
            <TabItem Header="Filtros &amp; Regras">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="15">
                        <TextBlock Text="Controle de Inclusão e Exclusão" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        
                        <Grid ColumnDefinitions="*,*">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                <TextBlock Text="Extensões Permitidas" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Text="{Binding ExtensionsText}" Watermark="ex: .pdf, .docx" Height="36" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                <TextBlock Text="Padrões para Ignorar" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Text="{Binding ExcludePatternsText}" Watermark="ex: temp, cache" Height="36" CornerRadius="8"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Validação por Regex (Nome do Arquivo)" Foreground="{DynamicResource TextSecondary}"/>
                            <TextBox Text="{Binding Job.NameRegex}" Watermark="Expressão regular opcional" Height="36" CornerRadius="8" FontFamily="Consolas"/>
                        </StackPanel>

                        <Separator Opacity="0.5"/>

                        <TextBlock Text="Restrições de Atributos" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        
                        <UniformGrid Columns="2">
                            <StackPanel Spacing="8" Margin="0,0,10,0">
                                <TextBlock Text="Tamanho Mínimo (KB)" Foreground="{DynamicResource TextSecondary}"/>
                                <NumericUpDown Value="{Binding Job.MinSizeKB}" Minimum="0" Height="36" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Spacing="8">
                                <TextBlock Text="Tamanho Máximo (KB)" Foreground="{DynamicResource TextSecondary}"/>
                                <NumericUpDown Value="{Binding Job.MaxSizeKB}" Minimum="0" Height="36" CornerRadius="8"/>
                            </StackPanel>
                        </UniformGrid>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Modificado recentemente (dias)" Foreground="{DynamicResource TextSecondary}"/>
                            <NumericUpDown Value="{Binding Job.ModifiedWithinDays}" Minimum="0" Maximum="3650" Height="36" CornerRadius="8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ABA AVANÇADO -->
            <TabItem Header="Avançado &amp; Agendamento">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="15">
                        <TextBlock Text="FlowEngine Engine" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        
                        <UniformGrid Columns="2">
                            <CheckBox IsChecked="{Binding Job.SmartSync}" Content="SmartSync (Delta)"/>
                            <CheckBox IsChecked="{Binding Job.VerifyHash}" Content="Verificar Hash (DNA)"/>
                            <CheckBox IsChecked="{Binding Job.EnableTrash}" Content="Safe Trash (Lixeira)"/>
                            <CheckBox IsChecked="{Binding Job.WatchEnabled}" Content="Hotfolder (Real-time)"/>
                        </UniformGrid>

                        <StackPanel Spacing="8" IsVisible="{Binding Job.WatchEnabled}">
                            <TextBlock Text="Tempo de Estabilização (Settle Time)" Foreground="{DynamicResource TextSecondary}"/>
                            <NumericUpDown Value="{Binding Job.SettleTimeSeconds}" Minimum="1" Maximum="300" Height="36" CornerRadius="8"/>
                        </StackPanel>

                        <Separator Opacity="0.5"/>

                        <TextBlock Text="Scheduler Automático" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        <ComboBox ItemsSource="{Binding ScheduleTypes}" SelectedItem="{Binding Job.ScheduleType}" Width="250" Height="36" CornerRadius="8"/>
                        
                        <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource EqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.Interval}}" Spacing="8">
                            <TextBlock Text="Repetir a cada (minutos)"/>
                            <NumericUpDown Value="{Binding Job.IntervalMinutes}" Minimum="1" Maximum="1440" Height="36" CornerRadius="8"/>
                        </StackPanel>

                        <StackPanel IsVisible="{Binding Job.ScheduleType, Converter={StaticResource NotEqualsConverter}, ConverterParameter={x:Static enums:ScheduleType.None}}" Spacing="8">
                            <TextBlock Text="Executar no horário (HH:mm)"/>
                            <TextBox Text="{Binding Job.ScheduleTime}" Watermark="ex: 03:00" Height="36" CornerRadius="8"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ABA SHAREPOINT (Cloud Bridge) -->
            <TabItem Header="Cloud Bridge (SharePoint)">
                <ScrollViewer>
                    <StackPanel Spacing="20" Margin="15">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <material:MaterialIcon Kind="ShareVariant" Width="24" Height="24" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Integração Direta SharePoint / OneDrive" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <Border Background="{DynamicResource SuccessColor}" Opacity="0.1" CornerRadius="8" Padding="15">
                            <TextBlock Text="Habilite esta aba se o destino ou origem for uma biblioteca do SharePoint Online." FontSize="13" Foreground="{DynamicResource TextSecondary}"/>
                        </Border>

                        <StackPanel Spacing="15">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Site URL (SharePoint Site)" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Watermark="https://tenant.sharepoint.com/sites/NomeDoSite" Height="36" CornerRadius="8"/>
                            </StackPanel>

                            <Grid ColumnDefinitions="*,*">
                                <StackPanel Grid.Column="0" Margin="0,0,10,0" Spacing="8">
                                    <TextBlock Text="Tenant ID (Azure)" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBox Watermark="00000000-0000-..." Height="36" CornerRadius="8"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="10,0,0,0" Spacing="8">
                                    <TextBlock Text="Client ID (App Registration)" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBox Watermark="00000000-0000-..." Height="36" CornerRadius="8"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Spacing="8">
                                <TextBlock Text="Document Library Name" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBox Watermark="ex: Documentos Compartilhados" Height="36" CornerRadius="8"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Content="Testar Conexão Cloud" Classes="accent" HorizontalAlignment="Left" Padding="20,10" CornerRadius="8"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Botões de Ação Fixos -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="15">
            <Button Command="{Binding CancelCommand}" Content="Descartar" Padding="25,10" CornerRadius="10" Background="Transparent" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"/>
            <Button Command="{Binding SaveCommand}" Content="Salvar Tarefa" Padding="25,10" CornerRadius="10" Classes="accent" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</UserControl>
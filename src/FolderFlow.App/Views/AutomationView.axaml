<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:models="using:FolderFlow.Domain.Entities"
             xmlns:vo="using:FolderFlow.Domain.ValueObjects"
             xmlns:material="using:Material.Icons.Avalonia"
             x:Class="FolderFlow.App.Views.AutomationView"
             x:DataType="vm:AutomationViewModel">
    
    <UserControl.Styles>
        <!-- Chip Style for Filters -->
        <Style Selector="RadioButton.Chip">
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Name="ChipBorder" Background="{DynamicResource SidebarBackground}" 
                            BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1"
                            CornerRadius="20" Padding="12,6" Margin="0,0,10,0">
                        <TextBlock Name="ChipText" Text="{TemplateBinding Content}" 
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondary}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="RadioButton.Chip:checked /template/ Border#ChipBorder">
            <Setter Property="Background" Value="{DynamicResource AccentColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>
        <Style Selector="RadioButton.Chip:checked /template/ TextBlock#ChipText">
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="RadioButton.Chip:pointerover /template/ Border#ChipBorder">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>

        <Style Selector="Border.JobCard:pointerover">
            <Setter Property="Background" Value="{DynamicResource CardHoverBackground}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentColor}"/>
        </Style>
        
        <Style Selector="Border.Pulse material|MaterialIcon">
            <Style.Animations>
                <Animation Duration="0:0:2" IterationCount="Infinite">
                    <KeyFrame KeyTime="0:0:0"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                    <KeyFrame KeyTime="0:0:1"><Setter Property="Opacity" Value="0.4"/></KeyFrame>
                    <KeyFrame KeyTime="0:0:2"><Setter Property="Opacity" Value="1.0"/></KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*">
        
        <!-- HEADER PREMIUM -->
        <Border Grid.Row="0" Background="{DynamicResource SidebarBackground}" Padding="35,30" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <StackPanel Spacing="30">
                
                <!-- Title & Main Actions -->
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <TextBlock Text="Central de Automao" FontSize="34" FontWeight="Black" Foreground="{DynamicResource TextPrimary}" LetterSpacing="-1"/>
                            
                            <!-- Global Status Badges -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8" Margin="10,5,0,0">
                                <Border Background="{DynamicResource SuccessColor}" Opacity="0.1" CornerRadius="6" Padding="8,3">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <Ellipse Width="6" Height="6" Fill="{DynamicResource SuccessColor}"/>
                                        <TextBlock Text="{Binding ActiveExecutions.Count, StringFormat='{}{0} Ativos'}" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="{DynamicResource AccentColor}" Opacity="0.1" CornerRadius="6" Padding="8,3">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <material:MaterialIcon Kind="ClockOutline" Width="10" Foreground="{DynamicResource AccentColor}"/>
                                        <TextBlock Text="Fila Pronta" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        <TextBlock Text="Orquestre, monitore e gerencie seus fluxos de dados em um nico lugar" FontSize="15" Foreground="{DynamicResource TextSecondary}" Opacity="0.6"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Top">
                        <Button Command="{Binding CreateDirectCopyCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Height="44" CornerRadius="12" Padding="20,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <material:MaterialIcon Kind="Plus" Width="20" Height="20"/>
                                <TextBlock Text="Cpia Direta" FontWeight="Heavy"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding CreateWatchFolderCommand}" Classes="Success" Theme="{DynamicResource SolidButton}" Height="44" CornerRadius="12" Padding="20,0">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <material:MaterialIcon Kind="Radar" Width="20" Height="20"/>
                                <TextBlock Text="Watch Folder" FontWeight="Heavy"/>
                            </StackPanel>
                        </Button>
                        <Button Command="{Binding StopAllCommand}" Classes="Danger" Theme="{DynamicResource OutlineButton}" Width="44" Height="44" CornerRadius="12" ToolTip.Tip="Encerrar Todas as Atividades">
                            <material:MaterialIcon Kind="Power" Width="22"/>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search & Chips Filter -->
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <!-- Filters as Chips -->
                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <RadioButton Content="Todos" Classes="Chip" IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualsConverter}, ConverterParameter='Todos'}"/>
                        <RadioButton Content="Ativos" Classes="Chip" IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualsConverter}, ConverterParameter='Ativos'}"/>
                        <RadioButton Content="Pendentes" Classes="Chip" IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualsConverter}, ConverterParameter='Pendentes'}"/>
                        <RadioButton Content="Watchers" Classes="Chip" IsChecked="{Binding SelectedFilter, Converter={StaticResource EqualsConverter}, ConverterParameter='Watch Folder'}"/>
                    </StackPanel>

                    <TextBox Grid.Column="2" Text="{Binding SearchText}" Watermark="Buscar por nome ou caminho..." Width="300" Height="40" CornerRadius="12">
                        <TextBox.InnerLeftContent>
                            <material:MaterialIcon Kind="Magnify" Margin="12,0" Opacity="0.3"/>
                        </TextBox.InnerLeftContent>
                    </TextBox>

                    <!-- Batch Actions Bar (Floating Concept) -->
                    <Border Grid.Column="1" IsVisible="{Binding HasSelection}" Background="{DynamicResource AccentColor}" CornerRadius="12" Padding="20,5" Margin="20,0" HorizontalAlignment="Center" BoxShadow="0 4 15 0 #40000000">
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <TextBlock Text="{Binding SelectedCount, StringFormat='{}{0} selecionados'}" Foreground="White" VerticalAlignment="Center" FontWeight="Black" FontSize="12"/>
                            <Separator Width="1" Height="16" Background="#40FFFFFF"/>
                            <Button Command="{Binding RunSelectedCommand}" Background="Transparent" BorderThickness="0"><material:MaterialIcon Kind="Play" Foreground="White" Width="20"/></Button>
                            <Button Command="{Binding StopSelectedCommand}" Background="Transparent" BorderThickness="0"><material:MaterialIcon Kind="Stop" Foreground="White" Width="20"/></Button>
                            <Button Command="{Binding DeleteSelectedCommand}" Background="Transparent" BorderThickness="0"><material:MaterialIcon Kind="Delete" Foreground="White" Width="20"/></Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1">
            <StackPanel Margin="35" Spacing="35">
                
                <!-- PROCESSANDO AGORA -->
                <StackPanel IsVisible="{Binding ActiveExecutions.Count}" Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="Flash" Foreground="{DynamicResource SuccessColor}" Width="22" Height="22"/>
                        <TextBlock Text="PROCESSAMENTO EM TEMPO REAL" FontSize="12" FontWeight="Black" LetterSpacing="1.5" Opacity="0.4"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding ActiveExecutions}">
                        <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vo:JobProgressInfo">
                                <Border Width="380" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="20" Margin="0,0,20,20" 
                                        BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1.5" BoxShadow="0 2 10 0 #20000000">
                                    <StackPanel Spacing="12">
                                        <Grid ColumnDefinitions="*, Auto">
                                            <TextBlock Text="{Binding JobName}" FontWeight="ExtraBold" FontSize="18" LetterSpacing="-0.5" TextTrimming="CharacterEllipsis"/>
                                            <Border Grid.Column="1" Background="{DynamicResource SuccessColor}" CornerRadius="6" Padding="6,2" Margin="10,0,0,0">
                                                <TextBlock Text="{Binding Status}" FontSize="9" FontWeight="Black" Foreground="White"/>
                                            </Border>
                                        </Grid>
                                        <TextBlock Text="{Binding CurrentFile}" FontSize="11" Opacity="0.6" TextWrapping="NoWrap" MaxLines="1" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                                        <ProgressBar Value="{Binding TotalPercentage}" Height="6" CornerRadius="3" Foreground="{DynamicResource SuccessColor}"/>
                                        <Grid ColumnDefinitions="*, Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <material:MaterialIcon Kind="Speedometer" Width="14" Height="14" Opacity="0.5"/>
                                                <TextBlock Text="{Binding TransferSpeed, Converter={StaticResource FileSizeConverter}, StringFormat='{}{0}/s'}" FontSize="11" FontWeight="Bold"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TotalPercentage, StringFormat={}{0:F0}%}" FontSize="12" FontWeight="Black" Foreground="{DynamicResource SuccessColor}"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- BIBLIOTECA -->
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <material:MaterialIcon Kind="LibraryOutline" Foreground="{DynamicResource AccentColor}" Width="22" Height="22"/>
                        <TextBlock Text="SUAS TAREFAS CONFIGURADAS" FontSize="12" FontWeight="Black" LetterSpacing="1.5" Opacity="0.4"/>
                    </StackPanel>

                    <ItemsControl ItemsSource="{Binding AllJobs}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:JobItemViewModel">
                                <Border Classes="JobCard" Background="{DynamicResource CardBackground}" CornerRadius="16" Padding="0" Margin="0,0,0,12" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" ClipToBounds="True">
                                    <StackPanel>
                                        <!-- Header Corrigido -->
                                        <Grid ColumnDefinitions="Auto, Auto, *, Auto" Margin="20,15" Background="Transparent">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected}" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                            
                                            <Border Grid.Column="1" Width="44" Height="44" CornerRadius="12" Margin="0,0,15,0"
                                                    Background="#1A888888" Classes.Pulse="{Binding Job.WatchEnabled}">
                                                <material:MaterialIcon Kind="{Binding Job.WatchEnabled, Converter={StaticResource BoolToIconConverter}, ConverterParameter='Radar:FileMoveOutline'}" 
                                                                      Classes.Watch="{Binding Job.WatchEnabled}"
                                                                      Classes.Direct="{Binding !Job.WatchEnabled}"
                                                                      Width="22" Height="22"/>
                                            </Border>

                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                                                <TextBlock Text="{Binding Job.Name}" FontWeight="Bold" FontSize="16" LetterSpacing="-0.3" TextTrimming="CharacterEllipsis"/>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold" Foreground="{Binding Progress, Converter={StaticResource StatusToProgressColorConverter}}" TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="|" FontSize="11" Opacity="0.3"/>
                                                    <TextBlock Text="{Binding Job.Mode}" FontSize="11" Opacity="0.6"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                <Button Command="{Binding RunNowCommand}" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6" ToolTip.Tip="Iniciar">
                                                    <material:MaterialIcon Kind="Play" Width="18" Foreground="{DynamicResource SuccessColor}"/>
                                                </Button>
                                                <Button Command="{Binding $parent[UserControl].((vm:AutomationViewModel)DataContext).StopJobCommand}" CommandParameter="{Binding Job.Id}" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6" ToolTip.Tip="Parar">
                                                    <material:MaterialIcon Kind="Stop" Width="18" Foreground="{DynamicResource DangerColor}"/>
                                                </Button>
                                                <Button Command="{Binding EditCommand}" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6" ToolTip.Tip="Editar">
                                                    <material:MaterialIcon Kind="Pencil" Width="16" Opacity="0.7"/>
                                                </Button>
                                                <Button Command="{Binding $parent[UserControl].((vm:AutomationViewModel)DataContext).DeleteJobCommand}" CommandParameter="{Binding Job.Id}" Classes="Danger" Theme="{DynamicResource OutlineButton}" Width="34" Height="34" CornerRadius="6" ToolTip.Tip="Excluir">
                                                    <material:MaterialIcon Kind="DeleteOutline" Width="16"/>
                                                </Button>
                                                <Separator Width="1" Height="20" Background="{DynamicResource CardBorderBrush}" Margin="4,0"/>
                                                <Button Command="{Binding ToggleExpandCommand}" Theme="{DynamicResource TransparentButton}" Width="34" Height="34" CornerRadius="6">
                                                    <material:MaterialIcon Kind="{Binding IsExpanded, Converter={StaticResource EqualsConverter}, ConverterParameter='True:ChevronUp;False:ChevronDown'}" Width="22" Opacity="0.6"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>

                                        <!-- Expanded Details -->
                                        <Border IsVisible="{Binding IsExpanded}" Background="{DynamicResource SidebarBackground}" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
                                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, 320">
                                                <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnDefinitions="*, *" Margin="0,0,0,20">
                                                    <Grid Grid.Column="0" ColumnDefinitions="Auto, *, Auto" Margin="0,0,15,0">
                                                        <TextBlock Grid.Column="0" Text="ORIGEM:" FontSize="10" FontWeight="Black" Opacity="0.4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Job.SourcePath}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Job.SourcePath}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Command="{Binding OpenSourceCommand}" Theme="{DynamicResource TransparentButton}" Opacity="0.5" Padding="5" Margin="5,0,0,0"><material:MaterialIcon Kind="FolderOpen" Width="14"/></Button>
                                                    </Grid>
                                                    <Grid Grid.Column="1" ColumnDefinitions="Auto, *, Auto" Margin="15,0,0,0">
                                                        <TextBlock Grid.Column="0" Text="DESTINO:" FontSize="10" FontWeight="Black" Opacity="0.4" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Job.TargetPath}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" ToolTip.Tip="{Binding Job.TargetPath}" VerticalAlignment="Center"/>
                                                        <Button Grid.Column="2" Command="{Binding OpenTargetCommand}" Theme="{DynamicResource TransparentButton}" Opacity="0.5" Padding="5" Margin="5,0,0,0"><material:MaterialIcon Kind="FolderOpen" Width="14"/></Button>
                                                    </Grid>
                                                </Grid>

                                                <StackPanel Grid.Row="1" Grid.Column="0" Spacing="15" VerticalAlignment="Top">
                                                    <UniformGrid Columns="2">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="FREQUÊNCIA" FontSize="9" Opacity="0.4"/>
                                                            <TextBlock Text="{Binding Job.ScheduleType}" FontSize="12" FontWeight="Bold"/>
                                                        </StackPanel>
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="VELOCIDADE" FontSize="9" Opacity="0.4"/>
                                                            <TextBlock Text="{Binding SpeedText}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                                        </StackPanel>
                                                    </UniformGrid>
                                                </StackPanel>

                                                <Border Grid.Row="1" Grid.Column="1" Background="#121212" CornerRadius="10" Padding="12" MinHeight="100">
                                                    <StackPanel Spacing="8">
                                                        <TextBlock Text="TERMINAL LIVE" FontSize="9" FontWeight="Bold" Foreground="#00FF00" Opacity="0.5"/>
                                                        <ItemsControl ItemsSource="{Binding RecentFilesLog}">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate><TextBlock Text="{Binding}" FontSize="10" Foreground="#00FF00" FontFamily="Consolas, Courier New" TextTrimming="CharacterEllipsis"/></DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

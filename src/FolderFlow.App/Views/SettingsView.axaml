<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="FolderFlow.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="30">
            <TextBlock Text="Configurações do Sistema" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            
            <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="12" Padding="25">
                <StackPanel Spacing="25">
                    <!-- Apresentação -->
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="Palette" Width="20" Height="20" Foreground="#3B82F6"/>
                            <TextBlock Text="Aparência e Localização" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <Grid ColumnDefinitions="200, *" RowDefinitions="Auto, Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Tema do Aplicativo:" VerticalAlignment="Center" Foreground="Gray"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}" Width="250" Margin="0,0,0,15"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Idioma (Cultura):" VerticalAlignment="Center" Foreground="Gray"/>
                            <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding Settings.Language}" Width="250"/>
                        </Grid>
                    </StackPanel>

                    <Separator/>

                    <!-- Suporte -->
                    <StackPanel Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="Heart" Width="20" Height="20" Foreground="#EF4444"/>
                            <TextBlock Text="Suporte e Doação" FontSize="18" FontWeight="SemiBold"/>
                        </StackPanel>
                        <TextBlock Text="Se o FolderFlow tem sido útil para você, considere apoiar o desenvolvedor!" FontSize="13" Foreground="Gray" TextWrapping="Wrap"/>
                        
                        <Border Background="{DynamicResource SystemRegionBrush}" CornerRadius="8" Padding="15">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Qrcode" Width="20" Height="20" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                                    <TextBlock Text="Chave PIX: contato@raillen.site" FontWeight="Bold" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Comprar um Café (Buy Me a Coffee)" Classes="accent" CornerRadius="6" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Button Command="{Binding SaveSettingsCommand}" Classes="accent" CornerRadius="6" Padding="20,12" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <material:MaterialIcon Kind="ContentSave" Width="18" Height="18"/>
                    <TextBlock Text="Salvar Configurações" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>

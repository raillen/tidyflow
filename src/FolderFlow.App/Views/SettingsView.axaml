<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:FolderFlow.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="700"
             x:Class="FolderFlow.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Margin="25" Spacing="30">
            <StackPanel Spacing="5">
                <TextBlock Text="Configurações do Ecossistema" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Personalize sua experiência visual e funcional no FolderFlow" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>
            
            <!-- Cards de Configuração -->
            <StackPanel Spacing="20">
                
                <!-- Aparência Premium -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="25">
                    <StackPanel Spacing="25">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <material:MaterialIcon Kind="Palette" Width="24" Height="24" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Visual Engine (Glass &amp; Themes)" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="250, *" RowDefinitions="Auto, Auto, Auto" Margin="0,10,0,0">
                            <!-- Tema -->
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Esquema de Cores:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}" Width="250" Margin="0,0,0,20"/>
                            
                            <!-- Opacidade -->
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Opacidade do Vidro (Glass):" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
                                <Slider Value="{Binding GlassOpacity}" Minimum="0.1" Maximum="1.0" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GlassOpacity, StringFormat='{}{0:P0}'}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>

                            <!-- Idioma -->
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Cultura e Localização:" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Languages}" SelectedItem="{Binding Settings.Language}" Width="250"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Comportamento -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="25">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <material:MaterialIcon Kind="AutoFix" Width="24" Height="24" Foreground="{DynamicResource SuccessColor}"/>
                            <TextBlock Text="Sistema e Background" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <StackPanel Spacing="15" Margin="0,10,0,0">
                            <CheckBox IsChecked="{Binding Settings.StartAtStartup}" Content="{lcl:Lcl StartAtStartup}"/>
                            <CheckBox IsChecked="{Binding Settings.ShowNotifications}" Content="{lcl:Lcl ShowNotifications}"/>
                            <CheckBox IsChecked="{Binding Settings.CloseToTray}" Content="{lcl:Lcl CloseToTray}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Monitoramento -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="25">
                    <StackPanel Spacing="20">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <material:MaterialIcon Kind="Monitor" Width="24" Height="24" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Monitoramento e Performance" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>

                        <Grid ColumnDefinitions="250, *" Margin="0,10,0,0">
                            <TextBlock Grid.Column="0" Text="Taxa de Atualização do Monitor (seg):" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="15">
                                <Slider Value="{Binding Settings.SystemMonitorUpdateIntervalSeconds}" Minimum="1" Maximum="10" Width="200" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding Settings.SystemMonitorUpdateIntervalSeconds}" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Suporte -->
                <Border BorderBrush="{DynamicResource SuccessColor}" BorderThickness="1" CornerRadius="16">
                    <Panel>
                        <!-- Background Layer with low opacity -->
                        <Border Background="{DynamicResource SuccessColor}" Opacity="0.1" CornerRadius="16"/>
                        
                        <!-- Content Layer fully opaque -->
                        <Border Padding="25">
                            <StackPanel Spacing="15">
                                <StackPanel Orientation="Horizontal" Spacing="15">
                                    <material:MaterialIcon Kind="HeartPulse" Width="24" Height="24" Foreground="{DynamicResource SuccessColor}"/>
                                    <TextBlock Text="Apoie o Desenvolvimento" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                </StackPanel>
                                <TextBlock Text="O FolderFlow é gratuito e open-source. Se ele economiza seu tempo, considere uma doação via PIX." FontSize="13" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                                <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,10,0,0">
                                    <Border Background="{DynamicResource CardBackground}" CornerRadius="8" Padding="15,8">
                                        <TextBlock Text="PIX: contato@raillen.site" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                                    </Border>
                                    <Button Content="Buy Me a Coffee" Classes="Secondary" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Height="36"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Panel>
                </Border>

            </StackPanel>

            <Button Command="{Binding SaveSettingsCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="10" Padding="30,15" HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <material:MaterialIcon Kind="ContentSaveCheck" Width="20" Height="20"/>
                    <TextBlock Text="Salvar Alterações Premium" VerticalAlignment="Center" FontWeight="Bold" FontSize="16"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </ScrollViewer>
</UserControl>
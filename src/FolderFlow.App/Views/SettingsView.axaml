<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:FolderFlow.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="1200"
             x:Class="FolderFlow.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    <ScrollViewer>
        <StackPanel Margin="25" Spacing="25">
            <StackPanel Spacing="5">
                <TextBlock Text="{lcl:Lcl AdvancedSettings}" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="{lcl:Lcl SettingsDesc}" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>

            <!-- Engine & Performance -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="Speedometer" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl EnginePerformance}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" RowDefinitions="Auto, Auto" Margin="0,10,0,0">
                        <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,15,15">
                            <TextBlock Text="{lcl:Lcl Parallelism}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Threads}" SelectedItem="{Binding Settings.MaxDegreeOfParallelism}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            <TextBlock Text="{lcl:Lcl ParallelismDesc}" FontSize="11" Opacity="0.5" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Grid.Row="0" Margin="15,0,0,15">
                            <TextBlock Text="{lcl:Lcl ProcessPriority}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Settings.ProcessPriority}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            <TextBlock Text="{lcl:Lcl PriorityDesc}" FontSize="11" Opacity="0.5" Margin="0,5,0,0"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="10">
                        <TextBlock Text="{lcl:Lcl GlobalBandwidth}" FontSize="12" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <Slider Grid.Column="0" Value="{Binding Settings.BandwidthLimitBytes}" Minimum="0" Maximum="104857600" SmallChange="1048576"/>
                            <TextBlock Grid.Column="1" Text="{Binding Settings.BandwidthLimitBytes, Converter={StaticResource FileSizeConverter}, StringFormat='{}{0}/s'}" Margin="15,0,0,0" VerticalAlignment="Center" Width="80" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        </Grid>
                        <TextBlock Text="{lcl:Lcl BandwidthDesc}" FontSize="11" Opacity="0.5"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Security & Privacy -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="ShieldLockOutline" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl SecurityPrivacy}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *">
                        <StackPanel Grid.Column="0" Spacing="15">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{lcl:Lcl AccessPin}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Settings.AppPin}" PasswordChar="*" Watermark="{lcl:Lcl PinWatermark}" CornerRadius="8"/>
                                <TextBlock Text="{lcl:Lcl PinDesc}" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <CheckBox IsChecked="{Binding Settings.LockOnMinimize}" Content="{lcl:Lcl LockOnMinimize}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="30,0,0,0" Spacing="5">
                            <TextBlock Text="{lcl:Lcl EncryptionKey}" FontSize="12" FontWeight="SemiBold"/>
                            <TextBox Text="{Binding Settings.MasterEncryptionKey}" PasswordChar="*" Watermark="{lcl:Lcl EncryptionKeyWatermark}" CornerRadius="8"/>
                            <TextBlock Text="{lcl:Lcl EncryptionDesc}" FontSize="11" Opacity="0.5"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Notifications Pro -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="BellBadgeOutline" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl ExternalNotifications}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*, 150" Margin="0,0,0,10">
                            <StackPanel Grid.Column="0" Spacing="5">
                                <TextBlock Text="{lcl:Lcl WebhookUrl}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding Settings.WebhookUrl}" Watermark="{lcl:Lcl WebhookUrlWatermark}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="5">
                                <TextBlock Text="{lcl:Lcl Type}" FontSize="12" FontWeight="SemiBold"/>
                                <ComboBox ItemsSource="{Binding WebhookTypes}" SelectedItem="{Binding Settings.WebhookType}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{lcl:Lcl SmtpEmailHeader}" FontSize="12" FontWeight="Bold" Opacity="0.8" Margin="0,10,0,0"/>
                        <Grid ColumnDefinitions="*, *, *">
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="{lcl:Lcl SmtpServer}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Settings.SmtpHost}" Watermark="{lcl:Lcl SmtpHostWatermark}" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                <TextBlock Text="{lcl:Lcl Port}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                <NumericUpDown Value="{Binding Settings.SmtpPort}" Minimum="1" Maximum="65535" CornerRadius="8"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="{lcl:Lcl DestEmail}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                <TextBox Text="{Binding Settings.NotificationEmail}" Watermark="{lcl:Lcl DestEmailWatermark}" CornerRadius="8"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Orientation="Horizontal" Spacing="25" Margin="0,10,0,0">
                            <CheckBox IsChecked="{Binding Settings.EnableSmtp}" Content="{lcl:Lcl EnableSmtp}"/>
                            <CheckBox IsChecked="{Binding Settings.NotifyOnSuccess}" Content="{lcl:Lcl NotifyOnSuccess}"/>
                            <CheckBox IsChecked="{Binding Settings.NotifyOnError}" Content="{lcl:Lcl NotifyOnError}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Automation & Windows -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="MicrosoftWindows" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl AutomationSystem}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <StackPanel Spacing="15">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{lcl:Lcl StartWithWindows}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{lcl:Lcl StartWithWindowsDesc}" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.StartAtStartup}" OnContent="" OffContent="" />
                        </Grid>

                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{lcl:Lcl CloseToTray}" FontSize="12" FontWeight="SemiBold"/>
                                <TextBlock Text="{lcl:Lcl CloseToTrayDesc}" FontSize="11" Opacity="0.5"/>
                            </StackPanel>
                            <ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.CloseToTray}" OnContent="" OffContent="" />
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Database Maintenance -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="DatabaseSettingsOutline" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl MaintenanceData}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{lcl:Lcl LogRetention}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding RetentionOptions}" SelectedItem="{Binding Settings.LogRetentionDays}" Width="150" CornerRadius="8"/>
                            <TextBlock Text="{lcl:Lcl LogRetentionDesc}" FontSize="11" Opacity="0.5" Margin="0,5,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Bottom">
                            <TextBlock Text="{Binding DatabaseSizeText}" FontSize="12" FontWeight="Bold" HorizontalAlignment="Right"/>
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <Button Command="{Binding PurgeOldLogsCommand}" Theme="{DynamicResource OutlineButton}" Content="{lcl:Lcl ClearNow}" FontSize="11" Padding="15,5" CornerRadius="6"/>
                                <Button Command="{Binding OptimizeDatabaseCommand}" Classes="Secondary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl OptimizeDatabase}" FontSize="11" Padding="15,5" CornerRadius="6"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Support & Donation -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="#1AEE4444" BorderThickness="1">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Grid.Column="0" Spacing="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="Heart" Width="20" Height="20" Foreground="#EF4444"/>
                            <TextBlock Text="{lcl:Lcl SupportTitle}" FontSize="13" FontWeight="Bold" LetterSpacing="1"/>
                        </StackPanel>
                        <TextBlock Text="{lcl:Lcl SupportDesc}" FontSize="12" Opacity="0.6" TextWrapping="Wrap" MaxWidth="500" HorizontalAlignment="Left"/>
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Spacing="5">
                                <TextBlock Text="{lcl:Lcl SupportPixLabel}" FontSize="11" FontWeight="Bold" Opacity="0.5"/>
                                <TextBlock Text="contato@raillen.site" FontSize="14" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Center">
                        <Button Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowDonateCommand}" 
                                Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="20,10">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <material:MaterialIcon Kind="HandHeartOutline" Width="18"/>
                                <TextBlock Text="{lcl:Lcl Donate}" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Visual & UI -->
            <Border Background="{DynamicResource SidebarBackground}" CornerRadius="16" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                <StackPanel Spacing="20">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="Palette" Width="20" Height="20" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="{lcl:Lcl VisualLanguage}" FontSize="13" FontWeight="Bold" LetterSpacing="1" Opacity="0.7"/>
                    </StackPanel>

                    <Grid ColumnDefinitions="*, *" Margin="0,10,0,0">
                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="{lcl:Lcl InterfaceTheme}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="15,0,0,0">
                            <TextBlock Text="{lcl:Lcl SystemLanguage}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Settings.Language}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                        </StackPanel>
                    </Grid>

                    <StackPanel Spacing="10">
                        <TextBlock Text="{lcl:Lcl GlassOpacity}" FontSize="12" FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*, Auto">
                            <Slider Grid.Column="0" Value="{Binding GlassOpacity}" Minimum="0.1" Maximum="1.0" SmallChange="0.05"/>
                            <TextBlock Grid.Column="1" Text="{Binding GlassOpacity, StringFormat={}{0:P0}}" Margin="15,0,0,0" VerticalAlignment="Center" Width="40" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Footer Actions -->
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right" Margin="0,10,0,0">
                <Button Command="{Binding LoadSettingsCommand}" Theme="{DynamicResource OutlineButton}" Content="{lcl:Lcl DiscardChanges}" Padding="20,10" CornerRadius="8"/>
                <Button Command="{Binding SaveSettingsCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl SaveSettings}" Padding="25,10" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
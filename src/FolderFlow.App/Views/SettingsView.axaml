<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:lcl="using:FolderFlow.App.Localization"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="850" d:DesignHeight="600"
             x:Class="FolderFlow.App.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
    
    <Grid RowDefinitions="*, Auto" Margin="0,35,0,0">
        <!-- Main Tab Control -->
        <TabControl Grid.Row="0" TabStripPlacement="Left">
            <TabControl.Styles>
                <Style Selector="TabItem">
                    <Setter Property="Padding" Value="15,12"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Width" Value="200"/>
                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                </Style>
            </TabControl.Styles>

            <!-- 1. GERAL -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="CogOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl General}"/>
                    </StackPanel>
                </TabItem.Header>
                
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl VisualLanguage}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="15">
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{lcl:Lcl InterfaceTheme}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding Settings.Theme}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{lcl:Lcl SystemLanguage}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding Languages}" SelectedItem="{Binding Settings.Language}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl GlassOpacity}" FontSize="12" FontWeight="SemiBold"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Grid.Column="0" Value="{Binding GlassOpacity}" Minimum="0.1" Maximum="1.0" SmallChange="0.05"/>
                                        <TextBlock Grid.Column="1" Text="{Binding GlassOpacity, StringFormat={}{0:P0}}" Margin="15,0,0,0" VerticalAlignment="Center" Width="40" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="{lcl:Lcl AutomationSystem}" FontSize="18" FontWeight="Bold" Margin="0,10,0,0"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="15">
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{lcl:Lcl StartWithWindows}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{lcl:Lcl StartWithWindowsDesc}" FontSize="11" Opacity="0.5"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.StartAtStartup}" OnContent="" OffContent="" />
                                </Grid>
                                <Grid ColumnDefinitions="*, Auto">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{lcl:Lcl CloseToTray}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBlock Text="{lcl:Lcl CloseToTrayDesc}" FontSize="11" Opacity="0.5"/>
                                    </StackPanel>
                                    <ToggleSwitch Grid.Column="1" IsChecked="{Binding Settings.CloseToTray}" OnContent="" OffContent="" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 2. PERFORMANCE -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="Speedometer" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Performance}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl EnginePerformance}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <Grid ColumnDefinitions="*, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{lcl:Lcl Parallelism}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding Threads}" SelectedItem="{Binding Settings.MaxDegreeOfParallelism}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Text="{lcl:Lcl ProcessPriority}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                        <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding Settings.ProcessPriority}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Spacing="10">
                                    <TextBlock Text="{lcl:Lcl GlobalBandwidth}" FontSize="12" FontWeight="SemiBold"/>
                                    <Grid ColumnDefinitions="*, Auto">
                                        <Slider Grid.Column="0" Value="{Binding Settings.BandwidthLimitBytes}" Minimum="0" Maximum="104857600" SmallChange="1048576"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Settings.BandwidthLimitBytes, Converter={StaticResource FileSizeConverter}, StringFormat='{}{0}/s'}" Margin="15,0,0,0" VerticalAlignment="Center" Width="80" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                    </Grid>
                                    <TextBlock Text="{lcl:Lcl BandwidthDesc}" FontSize="11" Opacity="0.5"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 3. SEGURANÇA -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="ShieldLockOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Security}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl SecurityPrivacy}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl AccessPin}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding Settings.AppPin}" PasswordChar="*" Watermark="{lcl:Lcl PinWatermark}" CornerRadius="8" MaxWidth="200" HorizontalAlignment="Left"/>
                                    <CheckBox IsChecked="{Binding Settings.LockOnMinimize}" Content="{lcl:Lcl LockOnMinimize}" Margin="0,5,0,0"/>
                                </StackPanel>
                                <Separator Background="{DynamicResource CardBorderBrush}"/>
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl EncryptionKey}" FontSize="12" FontWeight="SemiBold"/>
                                    <TextBox Text="{Binding Settings.MasterEncryptionKey}" PasswordChar="*" Watermark="{lcl:Lcl EncryptionKeyWatermark}" CornerRadius="8"/>
                                    <TextBlock Text="{lcl:Lcl EncryptionDesc}" FontSize="11" Opacity="0.5"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 4. NOTIFICAÇÕES -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="BellOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Notifications}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl ExternalNotifications}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <TextBlock Text="Webhooks" FontSize="14" FontWeight="Bold" Opacity="0.8"/>
                                <Grid ColumnDefinitions="*, 150">
                                    <StackPanel Grid.Column="0" Spacing="5">
                                        <TextBlock Text="{lcl:Lcl WebhookUrl}" FontSize="12" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding Settings.WebhookUrl}" Watermark="{lcl:Lcl WebhookUrlWatermark}" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="15,0,0,0" Spacing="5">
                                        <TextBlock Text="{lcl:Lcl Type}" FontSize="12" FontWeight="SemiBold"/>
                                        <ComboBox ItemsSource="{Binding WebhookTypes}" SelectedItem="{Binding Settings.WebhookType}" HorizontalAlignment="Stretch" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>
                                
                                <Separator Background="{DynamicResource CardBorderBrush}"/>
                                
                                <TextBlock Text="{lcl:Lcl SmtpEmailHeader}" FontSize="14" FontWeight="Bold" Opacity="0.8"/>
                                <Grid ColumnDefinitions="*, 100, *">
                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                        <TextBlock Text="{lcl:Lcl SmtpServer}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Settings.SmtpHost}" Watermark="smtp.exemplo.com" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="10,0,10,0">
                                        <TextBlock Text="{lcl:Lcl Port}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                        <NumericUpDown Value="{Binding Settings.SmtpPort}" Minimum="1" Maximum="65535" CornerRadius="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                        <TextBlock Text="{lcl:Lcl DestEmail}" FontSize="11" Opacity="0.6" Margin="0,0,0,5"/>
                                        <TextBox Text="{Binding Settings.NotificationEmail}" Watermark="email@exemplo.com" CornerRadius="8"/>
                                    </StackPanel>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Spacing="20">
                                    <CheckBox IsChecked="{Binding Settings.EnableSmtp}" Content="{lcl:Lcl EnableSmtp}"/>
                                    <CheckBox IsChecked="{Binding Settings.NotifyOnSuccess}" Content="{lcl:Lcl NotifyOnSuccess}"/>
                                    <CheckBox IsChecked="{Binding Settings.NotifyOnError}" Content="{lcl:Lcl NotifyOnError}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 5. MANUTENÇÃO -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="DatabaseOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl Maintenance}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl MaintenanceData}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="8">
                                    <TextBlock Text="{lcl:Lcl LogRetention}" FontSize="12" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding RetentionOptions}" SelectedItem="{Binding Settings.LogRetentionDays}" Width="150" CornerRadius="8"/>
                                    <TextBlock Text="{lcl:Lcl LogRetentionDesc}" FontSize="11" Opacity="0.5"/>
                                </StackPanel>
                                
                                <Separator Background="{DynamicResource CardBorderBrush}"/>
                                
                                <StackPanel Spacing="15">
                                    <TextBlock Text="{Binding DatabaseSizeText}" FontSize="12" FontWeight="Bold"/>
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <Button Command="{Binding PurgeOldLogsCommand}" Theme="{DynamicResource OutlineButton}" Content="{lcl:Lcl ClearNow}" FontSize="12" Padding="20,8" CornerRadius="8"/>
                                        <Button Command="{Binding OptimizeDatabaseCommand}" Classes="Secondary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl OptimizeDatabase}" FontSize="12" Padding="20,8" CornerRadius="8"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 6. APOIO -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="HeartOutline" Width="18" Foreground="#EF4444"/>
                        <TextBlock Text="{lcl:Lcl Support}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="20">
                        <TextBlock Text="{lcl:Lcl SupportTitle}" FontSize="18" FontWeight="Bold"/>
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="25" BorderBrush="#1AEE4444" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <TextBlock Text="{lcl:Lcl SupportDesc}" FontSize="13" Opacity="0.7" TextWrapping="Wrap"/>
                                <StackPanel Spacing="5">
                                    <TextBlock Text="{lcl:Lcl SupportPixLabel}" FontSize="11" FontWeight="Bold" Opacity="0.5"/>
                                    <TextBlock Text="contato@raillen.site" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource AccentColor}"/>
                                </StackPanel>
                                <Button Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ShowDonateCommand}" 
                                        Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="25,12" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <material:MaterialIcon Kind="HandHeartOutline" Width="20"/>
                                        <TextBlock Text="{lcl:Lcl Donate}" FontWeight="Bold"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- 7. SOBRE -->
            <TabItem>
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <material:MaterialIcon Kind="InformationOutline" Width="18"/>
                        <TextBlock Text="{lcl:Lcl About}"/>
                    </StackPanel>
                </TabItem.Header>
                <ScrollViewer>
                    <StackPanel Margin="20" Spacing="25">
                        <TextBlock Text="{lcl:Lcl AboutFolderFlow}" FontSize="18" FontWeight="Bold"/>
                        
                        <Border Background="{DynamicResource SidebarBackground}" CornerRadius="12" Padding="25" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                            <StackPanel Spacing="20">
                                <StackPanel Spacing="10">
                                    <TextBlock Text="FolderFlow Pro" FontSize="22" FontWeight="Black" Foreground="{DynamicResource AccentColor}"/>
                                    <TextBlock Text="v1.3.2 (April 2026)" FontSize="12" Opacity="0.5"/>
                                </StackPanel>

                                <TextBlock Text="O FolderFlow nasceu para simplificar o gerenciamento de backups e a organização de arquivos em larga escala, unindo performance industrial com uma interface moderna e intuitiva." 
                                           TextWrapping="Wrap" FontSize="14" Opacity="0.8" LineHeight="22"/>

                                <Separator Background="{DynamicResource CardBorderBrush}"/>

                                <StackPanel Spacing="15">
                                    <TextBlock Text="Desenvolvido por Raillen Santos" FontSize="14" FontWeight="Bold"/>
                                    <TextBlock Text="Software Engineer focado em arquiteturas escaláveis e experiências de usuário fluidas." 
                                               TextWrapping="Wrap" FontSize="13" Opacity="0.7"/>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="15">
                                        <Button Command="{Binding OpenLinkCommand}" CommandParameter="https://github.com/raillen" Theme="{DynamicResource OutlineButton}" Padding="15,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <material:MaterialIcon Kind="Github" Width="18"/>
                                                <TextBlock Text="GitHub"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Command="{Binding OpenLinkCommand}" CommandParameter="https://www.linkedin.com/in/raillen-santos/" Theme="{DynamicResource OutlineButton}" Padding="15,8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <material:MaterialIcon Kind="Linkedin" Width="18"/>
                                                <TextBlock Text="LinkedIn"/>
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                </StackPanel>

                                <Button Command="{Binding ShowChangelogCommand}" Theme="{DynamicResource SolidButton}" Classes="Secondary" CornerRadius="8" Padding="20,10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <material:MaterialIcon Kind="History" Width="18"/>
                                        <TextBlock Text="Ver Changelog"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Fixed Footer Actions -->
        <Border Grid.Row="1" Background="{DynamicResource AppBackground}" Padding="20,15" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Right">
                <Button Command="{Binding LoadSettingsCommand}" Theme="{DynamicResource OutlineButton}" Content="{lcl:Lcl DiscardChanges}" Padding="20,10" CornerRadius="8"/>
                <Button Command="{Binding SaveSettingsCommand}" Classes="Primary" Theme="{DynamicResource SolidButton}" Content="{lcl:Lcl SaveSettings}" Padding="30,10" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
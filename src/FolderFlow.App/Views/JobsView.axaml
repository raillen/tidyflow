<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:v="using:FolderFlow.App.Views"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="750"
             x:Class="FolderFlow.App.Views.JobsView"
             x:DataType="vm:JobsViewModel">
    <Grid RowDefinitions="Auto, *">
        <!-- Toolbar Superior Premium -->
        <StackPanel Grid.Row="0" Margin="20,20,20,15" Spacing="25">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Grid.Column="0" Spacing="5">
                    <TextBlock Text="Fila de Automao" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                    <TextBlock Text="Gerencie suas tarefas de sincronizao e monitoramento" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
                </StackPanel>

                <!-- Progresso Global Ativo -->
                <Border Grid.Column="1" IsVisible="{Binding IsRunning}" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource AccentColor}" BorderThickness="1" CornerRadius="12" Padding="15,10">
                    <StackPanel Orientation="Horizontal" Spacing="15">
                        <material:MaterialIcon Kind="Sync" Width="20" Height="20" Foreground="{DynamicResource AccentColor}">
                            <material:MaterialIcon.Styles>
                                <Style Selector="material|MaterialIcon">
                                    <Style.Animations>
                                        <Animation Duration="0:0:2" IterationCount="Infinite">
                                            <KeyFrame KeyTime="0:0:0"><Setter Property="RotateTransform.Angle" Value="0"/></KeyFrame>
                                            <KeyFrame KeyTime="0:0:2"><Setter Property="RotateTransform.Angle" Value="360"/></KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </material:MaterialIcon.Styles>
                        </material:MaterialIcon>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentJobProgress.JobName}" FontSize="12" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                            <ProgressBar Value="{Binding CurrentJobProgress.Percentage}" Minimum="0" Maximum="100" Width="120" Height="6" CornerRadius="3" Margin="0,4,0,0"/>
                        </StackPanel>
                        <TextBlock Text="{Binding CurrentJobProgress.Percentage, StringFormat='{}{0:F0}%'}" FontSize="14" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource AccentColor}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Actions & Search -->
            <Grid ColumnDefinitions="Auto, *, Auto">
                <TextBox Grid.Column="0" Text="{Binding SearchText}" Watermark="Pesquisar tarefas..." Width="300" Height="36" CornerRadius="8" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}">
                    <TextBox.InnerLeftContent>
                        <material:MaterialIcon Kind="Magnify" Margin="10,0" Foreground="{DynamicResource TextSecondary}"/>
                    </TextBox.InnerLeftContent>
                </TextBox>

                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                    <Button Command="{Binding RunAllCommand}" Classes="Success" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8" Height="36">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="Play" Width="18" Height="18"/>
                            <TextBlock Text="Rodar Tudo" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding StopAllCommand}" Classes="Danger" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8" Height="36">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="Stop" Width="18" Height="18"/>
                            <TextBlock Text="Parar Tudo" VerticalAlignment="Center" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                    <Separator Width="1" Height="24" Background="{DynamicResource CardBorderBrush}" Margin="5,0"/>
                    
                    <Button Classes="Primary" Theme="{DynamicResource SolidButton}" CornerRadius="8" Padding="15,8" Height="36">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="PlusThick" Width="18" Height="18"/>
                            <TextBlock Text="Nova Tarefa" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            <material:MaterialIcon Kind="ChevronDown" Width="14" Height="14"/>
                        </StackPanel>
                        <Button.Flyout>
                            <MenuFlyout Placement="BottomEdgeAlignedRight">
                                <MenuItem Header="Cpia Direta" Command="{Binding CreateDirectCopyJobCommand}">
                                    <MenuItem.Icon><material:MaterialIcon Kind="FileMoveOutline" Foreground="{DynamicResource AccentColor}"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Watch Folder (Hotfolder)" Command="{Binding CreateWatchFolderJobCommand}">
                                    <MenuItem.Icon><material:MaterialIcon Kind="Radar" Foreground="{DynamicResource SuccessColor}"/></MenuItem.Icon>
                                </MenuItem>
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>

                    <Button Command="{Binding ImportJobsCommand}" Classes="Secondary" Theme="{DynamicResource OutlineButton}" CornerRadius="8" Padding="15,8" Height="36">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <material:MaterialIcon Kind="CloudDownloadOutline" Width="18" Height="18" Foreground="{DynamicResource SuccessColor}"/>
                            <TextBlock Text="Importar" VerticalAlignment="Center" FontWeight="Medium"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Conteudo Principal e Log -->
        <Grid Grid.Row="1" RowDefinitions="*, 250" Margin="20,0,20,20">
            <TabControl Grid.Row="0">
                <TabItem Header="Cpia Direta">
                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" ClipToBounds="True" Margin="0,10,0,0">
                        <DataGrid ItemsSource="{Binding FilteredDirectCopyJobs}" 
                                  AutoGenerateColumns="False" 
                                  IsReadOnly="True"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="{DynamicResource CardBorderBrush}"
                                  Background="Transparent">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected}" Header="Sel" />
                                <DataGridTemplateColumn Header="Nome" Width="*">
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,0">
                                            <material:MaterialIcon Kind="FolderSyncOutline" Foreground="{DynamicResource AccentColor}" Width="18" Height="18"/>
                                            <TextBlock Text="{Binding Job.Name}" VerticalAlignment="Center" FontWeight="Medium"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding Job.SourcePath}" Header="Origem" Width="1.5*" />
                                <DataGridTextColumn Binding="{Binding Job.TargetPath}" Header="Destino" Width="1.5*" />
                                <DataGridTemplateColumn Header="Aes" Width="220">
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center">
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).RunJobCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Executar Agora" Background="Transparent" Padding="5">
                                                <material:MaterialIcon Kind="Play" Foreground="{DynamicResource SuccessColor}" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).StopJobCommand}" CommandParameter="{Binding Job.Id}" ToolTip.Tip="Parar Operao" Background="Transparent" Padding="5">
                                                <material:MaterialIcon Kind="Stop" Foreground="{DynamicResource DangerColor}" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).RetryJobFailuresCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Reprocessar Falhas" Background="Transparent" Padding="5">
                                                <material:MaterialIcon Kind="SyncAlert" Foreground="{DynamicResource WarningColor}" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).EditJobCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Editar" Background="Transparent" Padding="5">
                                                <material:MaterialIcon Kind="PencilOutline" Foreground="{DynamicResource TextSecondary}" Width="20" Height="20"/>
                                            </Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).DeleteJobCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Excluir" Background="Transparent" Padding="5">
                                                <material:MaterialIcon Kind="TrashCanOutline" Foreground="{DynamicResource DangerColor}" Width="20" Height="20"/>
                                            </Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>
                
                <TabItem Header="Watch Folders (Hotfolder)">
                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12" ClipToBounds="True" Margin="0,10,0,0">
                        <DataGrid ItemsSource="{Binding FilteredWatchFolderJobs}" AutoGenerateColumns="False" Background="Transparent">
                             <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected}" Header="Sel" />
                                <DataGridTemplateColumn Header="Monitoramento Ativo" Width="*">
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,0">
                                            <material:MaterialIcon Kind="Radar" Foreground="{DynamicResource SuccessColor}" Width="18" Height="18"/>
                                            <TextBlock Text="{Binding Job.Name}" VerticalAlignment="Center" FontWeight="Bold"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Binding="{Binding Job.SourcePath}" Header="Origem" Width="1.5*" />
                                <DataGridTemplateColumn Header="Status">
                                    <DataTemplate>
                                        <Border Background="{DynamicResource SuccessColor}" Opacity="0.1" CornerRadius="10" Padding="8,2">
                                            <TextBlock Text="Observando" Foreground="{DynamicResource SuccessColor}" FontSize="11" FontWeight="Bold"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Aes" Width="150">
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).StopJobCommand}" CommandParameter="{Binding Job.Id}" ToolTip.Tip="Parar Monitoramento" Background="Transparent"><material:MaterialIcon Kind="Stop" Foreground="{DynamicResource DangerColor}"/></Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).EditJobCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Configurar" Background="Transparent"><material:MaterialIcon Kind="CogOutline"/></Button>
                                            <Button Command="{Binding $parent[UserControl].((vm:JobsViewModel)DataContext).PauseSelectedJobsCommand}" CommandParameter="{Binding Job}" ToolTip.Tip="Pausar" Background="Transparent"><material:MaterialIcon Kind="Pause" Foreground="{DynamicResource WarningColor}"/></Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </TabItem>
            </TabControl>

            <!-- Log de Operaes em Tempo Real -->
            <Border Grid.Row="1" Margin="0,15,0,0" Background="{DynamicResource SidebarBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="12">
                <Grid RowDefinitions="Auto, Auto, *">
                    <Border Grid.Row="0" Padding="15,10" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <Grid ColumnDefinitions="*, Auto">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <material:MaterialIcon Kind="Console" Width="16" Height="16" Foreground="{DynamicResource AccentColor}"/>
                                <TextBlock Text="LOG DE OPERAES EM TEMPO REAL" FontSize="11" FontWeight="Bold" VerticalAlignment="Center" LetterSpacing="1"/>
                            </StackPanel>
                            <Button Grid.Column="1" Command="{Binding ClearLogsCommand}" Background="Transparent" Padding="5">
                                <material:MaterialIcon Kind="Broom" Width="14" Height="14"/>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Filtros do Log -->
                    <Border Grid.Row="1" Background="{DynamicResource CardBackground}" Padding="15,8" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal" Spacing="20">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Operao:" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox ItemsSource="{Binding AvailableOperations}" SelectedItem="{Binding SelectedOperationFilter}" Width="140" Height="30" CornerRadius="6"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Tarefa:" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                <ComboBox ItemsSource="{Binding AvailableTasks}" SelectedItem="{Binding SelectedTaskFilter}" Width="180" Height="30" CornerRadius="6"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <ScrollViewer Grid.Row="2">
                        <ItemsControl ItemsSource="{Binding OperationLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:JobLogViewModel">
                                    <Border BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1" Padding="15,8">
                                        <Grid RowDefinitions="Auto, Auto">
                                            <Grid Grid.Row="0" ColumnDefinitions="80, 150, 120, *, 140, Auto">
                                                <TextBlock Grid.Column="0" Text="{Binding Progress.Timestamp, StringFormat='{}{0:HH:mm:ss}'}" VerticalAlignment="Center" FontSize="12" Foreground="{DynamicResource TextSecondary}"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Progress.JobName}" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0"/>
                                                <Border Grid.Column="2" HorizontalAlignment="Left" Background="{Binding Progress.Status, Converter={StaticResource StatusToProgressColorConverter}}" Opacity="0.1" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{Binding Progress.Status}" Foreground="{Binding Progress.Status, Converter={StaticResource StatusToProgressColorConverter}}" FontSize="10" FontWeight="Bold"/>
                                                </Border>
                                                <TextBlock Grid.Column="3" Text="{Binding Progress.CurrentFile}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="12" Margin="10,0"/>
                                                
                                                <Grid Grid.Column="4" ColumnDefinitions="*, Auto" VerticalAlignment="Center">
                                                    <ProgressBar Value="{Binding Progress.Status, Converter={StaticResource StatusToPercentageConverter}, FallbackValue={Binding Progress.CurrentFilePercentage}}" 
                                                                 Foreground="{Binding Progress.Status, Converter={StaticResource StatusToProgressColorConverter}}"
                                                                 Height="4" CornerRadius="2"/>
                                                    <TextBlock Grid.Column="1" Text="{Binding Progress.Status, Converter={StaticResource StatusToPercentageConverter}, FallbackValue={Binding Progress.CurrentFilePercentage}, StringFormat='{}{0:F0}%'}" FontSize="10" Margin="5,0,0,0" VerticalAlignment="Center"/>
                                                </Grid>

                                                <ToggleButton Grid.Column="5" IsChecked="{Binding IsExpanded}" Background="Transparent" Padding="5" Margin="5,0,0,0">
                                                    <material:MaterialIcon Kind="{Binding IsExpanded, Converter={StaticResource BoolToIconConverter}}" Width="16" Height="16"/>
                                                </ToggleButton>
                                            </Grid>

                                            <Border Grid.Row="1" IsVisible="{Binding IsExpanded}" Margin="0,10,0,5" Padding="15" Background="{DynamicResource AppBackground}" CornerRadius="8">
                                                <StackPanel Spacing="8">
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <TextBlock Grid.Column="0" Text="Detalhes:" FontWeight="SemiBold" Width="80" FontSize="12"/>
                                                        <TextBlock Grid.Column="1" Text="{Binding Progress.Details}" TextWrapping="Wrap" FontSize="12"/>
                                                    </Grid>
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <TextBlock Grid.Column="0" Text="Progresso:" FontWeight="SemiBold" Width="80" FontSize="12"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                                                            <ProgressBar Value="{Binding Progress.Percentage}" Width="150" Height="6" CornerRadius="3" VerticalAlignment="Center"/>
                                                            <TextBlock Text="{Binding Progress.ProcessedFiles}" FontSize="12"/>
                                                            <TextBlock Text="/" FontSize="12"/>
                                                            <TextBlock Text="{Binding Progress.TotalFiles}" FontSize="12"/>
                                                            <TextBlock Text="arquivos" FontSize="12"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Editor View Overlay (Absolute positioning on top of everything) -->
        <Grid Grid.RowSpan="2" IsVisible="{Binding IsEditing}" ZIndex="100">
            <Border Background="#A0000000" IsHitTestVisible="True" />
            <Border Background="{DynamicResource AppBackground}" 
                    BorderBrush="{DynamicResource CardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="16" 
                    Margin="40" 
                    Padding="0"
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    BoxShadow="0 25 60 0 #80000000"
                    MaxWidth="1000" MaxHeight="800">
                <v:JobEditorView DataContext="{Binding Editor}"/>
            </Border>
        </Grid>
        </Grid>
        </UserControl>
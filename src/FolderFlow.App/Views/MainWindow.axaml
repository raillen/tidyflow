<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FolderFlow.App.ViewModels"
        xmlns:v="using:FolderFlow.App.Views"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1150" d:DesignHeight="800"
        Width="1150" Height="800"
        MinWidth="1000" MinHeight="700"
        x:Class="FolderFlow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FolderFlow"
        TransparencyLevelHint="Mica,AcrylicBlur"
        Background="Transparent"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:JobsViewModel}">
            <v:JobsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <v:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <!-- Global Acrylic/Glass Background Layer -->
        <Border Background="{DynamicResource AppBackground}" 
                Opacity="{Binding Settings.Settings.GlassOpacity, FallbackValue=0.8}"/>

        <!-- Custom Draggable Area (TitleBar Area) -->
        <Border Name="DragArea" Height="45" VerticalAlignment="Top" Background="Transparent" />

        <SplitView IsPaneOpen="True"
                   DisplayMode="CompactInline"
                   CompactPaneLength="64"
                   OpenPaneLength="240"
                   Background="Transparent"
                   PaneBackground="Transparent">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Sidebar Background Layer (Glass) -->
                    <Border Grid.RowSpan="3" 
                            Background="{DynamicResource SidebarBackground}" 
                            Opacity="{Binding Settings.Settings.GlassOpacity, FallbackValue=0.9}"/>

                    <!-- Header/Logo Premium -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="16,45,16,30">
                        <material:MaterialIcon Kind="CloudSync" Width="32" Height="32" Foreground="{DynamicResource AccentColor}"/>
                        <TextBlock Text="FolderFlow" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Menu de Navegação -->
                    <StackPanel Grid.Row="1" Spacing="8" Margin="8,0,8,0">
                        <Button Command="{Binding NavigateToDashboardCommand}" 
                                AutomationProperties.Name="Dashboard"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <material:MaterialIcon Kind="ViewDashboard" Width="24" Height="24" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="Dashboard" VerticalAlignment="Center" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToJobsCommand}"
                                AutomationProperties.Name="Fila de Automação"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <material:MaterialIcon Kind="FormatListGroup" Width="24" Height="24" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="Fila de Automação" VerticalAlignment="Center" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToHistoryCommand}"
                                AutomationProperties.Name="Histórico e Logs"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <material:MaterialIcon Kind="History" Width="24" Height="24" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="Histórico e Logs" VerticalAlignment="Center" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- Configurações no Rodapé -->
                    <StackPanel Grid.Row="2" Margin="8,0,8,30">
                        <Button Command="{Binding NavigateToSettingsCommand}"
                                AutomationProperties.Name="Configurações"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="12">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <material:MaterialIcon Kind="Settings" Width="24" Height="24" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="Configurações" VerticalAlignment="Center" FontSize="15" FontWeight="Medium" Foreground="{DynamicResource TextPrimary}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <!-- Main Content Area -->
            <Grid Margin="0,40,0,0">
                <!-- Content Background Layer (Glass) -->
                <Border Background="{DynamicResource AppBackground}" 
                        Opacity="{Binding Settings.Settings.GlassOpacity, FallbackValue=1.0}"
                        CornerRadius="16,0,0,0" 
                        BoxShadow="{DynamicResource PremiumShadow}"/>

                <!-- Opaque Content Layer -->
                <TransitioningContentControl Content="{Binding CurrentPage}" Margin="24">
                    <TransitioningContentControl.PageTransition>
                        <CrossFade Duration="0:0:0.35" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Grid>
        </SplitView>
    </Panel>
</Window>
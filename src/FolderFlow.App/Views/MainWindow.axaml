<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FolderFlow.App.ViewModels"
        xmlns:v="using:FolderFlow.App.Views"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:lcl="using:FolderFlow.App.Localization"
        x:Class="FolderFlow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FolderFlow"
        Width="1100" Height="700"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        Background="{DynamicResource AppBackground}">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AutomationViewModel}">
            <v:AutomationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BlueprintViewModel}">
            <v:BlueprintView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <v:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <!-- Background -->
        <Border Background="{DynamicResource AppBackground}" IsHitTestVisible="False" />
        
        <SplitView IsPaneOpen="True"
                   DisplayMode="Inline"
                   OpenPaneLength="260"
                   Background="Transparent"
                   PaneBackground="Transparent">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto, *, Auto">
                    <Border Grid.RowSpan="3" Background="{DynamicResource SidebarBackground}" Opacity="{Binding Settings.Settings.GlassOpacity}" IsHitTestVisible="False"/>
                    
                    <!-- Header Sidebar (Logo) -->
                    <Grid Grid.Row="0" Margin="20,45,15,40">
                        <StackPanel Orientation="Horizontal" Spacing="16">
                            <Border Background="{DynamicResource AccentColor}" CornerRadius="8" Width="40" Height="40">
                                <material:MaterialIcon Kind="CloudSync" Width="24" Height="24" Foreground="White"/>
                            </Border>
                            <TextBlock Text="FolderFlow" Classes="H4" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                    </Grid>

                    <!-- Menu de Navegação -->
                    <StackPanel Grid.Row="1" Spacing="4" Margin="12,0">
                         <ListBox ItemsSource="{x:Null}" Background="Transparent" BorderThickness="0">
                             <ListBox.Styles>
                                <Style Selector="Button">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Padding" Value="15,12"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                </Style>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                                </Style>
                            </ListBox.Styles>

                            <Button Command="{Binding NavigateToDashboardCommand}"
                                    Background="{Binding CurrentPage, Converter={StaticResource ActivePageBackgroundConverter}, ConverterParameter='Dashboard'}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="ViewDashboardOutline" Width="22" Height="22" 
                                                          Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Dashboard'}"/>
                                    <TextBlock Text="{lcl:Lcl Dashboard}" VerticalAlignment="Center" FontWeight="Medium" 
                                               Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Dashboard'}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToAutomationCommand}"
                                    Background="{Binding CurrentPage, Converter={StaticResource ActivePageBackgroundConverter}, ConverterParameter='Automation'}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="SwapHorizontal" Width="22" Height="22" 
                                                          Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Automation'}"/>
                                    <TextBlock Text="{lcl:Lcl SidebarAutomation}" VerticalAlignment="Center" FontWeight="Medium" 
                                               Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Automation'}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToBlueprintCommand}"
                                    Background="{Binding CurrentPage, Converter={StaticResource ActivePageBackgroundConverter}, ConverterParameter='Blueprint'}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="FileTree" Width="22" Height="22" 
                                                          Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Blueprint'}"/>
                                    <TextBlock Text="{lcl:Lcl SidebarBlueprint}" VerticalAlignment="Center" FontWeight="Medium" 
                                               Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Blueprint'}"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToHistoryCommand}"
                                    Background="{Binding CurrentPage, Converter={StaticResource ActivePageBackgroundConverter}, ConverterParameter='History'}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="History" Width="22" Height="22" 
                                                          Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='History'}"/>
                                    <TextBlock Text="{lcl:Lcl SidebarAudit}" VerticalAlignment="Center" FontWeight="Medium" 
                                               Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='History'}"/>
                                </StackPanel>
                            </Button>
                        </ListBox>
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="12,0,12,30" Spacing="4">
                        <Button Command="{Binding ShowDonateCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="15,12">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <material:MaterialIcon Kind="Heart" Width="22" Height="22" Foreground="#EF4444"/>
                                <TextBlock Text="{lcl:Lcl Donate}" VerticalAlignment="Center" FontWeight="Medium" Classes="Secondary"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToSettingsCommand}"
                                Background="{Binding CurrentPage, Converter={StaticResource ActivePageBackgroundConverter}, ConverterParameter='Settings'}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                BorderThickness="0" CornerRadius="8" Padding="15,12">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <material:MaterialIcon Kind="SettingsOutline" Width="22" Height="22" 
                                                      Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Settings', FallbackValue={DynamicResource TextSecondary}}"/>
                                <TextBlock Text="{lcl:Lcl Settings}" VerticalAlignment="Center" FontWeight="Medium"
                                           Foreground="{Binding CurrentPage, Converter={StaticResource ActivePageForegroundConverter}, ConverterParameter='Settings', FallbackValue={DynamicResource TextSecondary}}"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <TransitioningContentControl Content="{Binding CurrentPage}" />
      </SplitView>

        <!-- Custom Draggable Area (TitleBar) -->
        <Border Name="DragArea" Height="45" VerticalAlignment="Top" Background="#00000000" IsHitTestVisible="True" />
    </Panel>
</Window>

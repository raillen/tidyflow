<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FolderFlow.App.ViewModels"
        xmlns:v="using:FolderFlow.App.Views"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:lcl="using:FolderFlow.App.Localization"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="850"
        Width="1200" Height="850"
        MinWidth="1000" MinHeight="700"
        x:Class="FolderFlow.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FolderFlow"
        Background="{DynamicResource AppBackground}"
        ExtendClientAreaToDecorationsHint="False"
        WindowStartupLocation="CenterScreen">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <v:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:AutomationViewModel}">
            <v:AutomationView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <v:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <v:SettingsView/>
        </DataTemplate>
    </Window.DataTemplates>

    <Panel>
        <!-- Layer de Fundo Global -->
        <Border Background="{DynamicResource AppBackground}" 
                Opacity="{Binding Settings.Settings.GlassOpacity, FallbackValue=0.8}"/>

        <SplitView IsPaneOpen="True"
                   DisplayMode="CompactInline"
                   CompactPaneLength="72"
                   OpenPaneLength="260"
                   Background="Transparent"
                   PaneBackground="Transparent">
            <SplitView.Pane>
                <Grid RowDefinitions="Auto,*,Auto">
                    <!-- Sidebar Background -->
                    <Border Grid.RowSpan="3" 
                            Background="{DynamicResource SidebarBackground}" 
                            Opacity="{Binding Settings.Settings.GlassOpacity, FallbackValue=0.9}"
                            BorderBrush="{DynamicResource SidebarBorderBrush}"
                            BorderThickness="0,0,1,0"/>

                    <!-- Logo Premium -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="20,45,20,40">
                        <Border Background="{DynamicResource AccentColor}" CornerRadius="8" Width="40" Height="40">
                            <material:MaterialIcon Kind="CloudSync" Width="24" Height="24" Foreground="White"/>
                        </Border>
                        <TextBlock Text="FolderFlow" Classes="H4" FontWeight="Bold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>

                    <!-- Menu de Navegação -->
                    <StackPanel Grid.Row="1" Spacing="4" Margin="12,0">
                         <ListBox ItemsSource="{x:Null}" Background="Transparent" BorderThickness="0">
                             <ListBox.Styles>
                                <Style Selector="Button">
                                    <Setter Property="HorizontalAlignment" Value="Stretch"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="CornerRadius" Value="8"/>
                                    <Setter Property="Padding" Value="12,10"/>
                                    <Setter Property="Margin" Value="0,2"/>
                                </Style>
                                <Style Selector="Button:pointerover">
                                    <Setter Property="Background" Value="{DynamicResource ButtonHoverBackground}"/>
                                </Style>
                            </ListBox.Styles>

                            <Button Command="{Binding NavigateToDashboardCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="ViewDashboardOutline" Width="22" Height="22" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="Dashboard" VerticalAlignment="Center" FontWeight="Medium" Classes="Secondary"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToAutomationCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="AutoFix" Width="22" Height="22" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="Automao" VerticalAlignment="Center" FontWeight="Medium" Classes="Secondary"/>
                                </StackPanel>
                            </Button>

                            <Button Command="{Binding NavigateToHistoryCommand}">
                                <StackPanel Orientation="Horizontal" Spacing="16">
                                    <material:MaterialIcon Kind="History" Width="22" Height="22" Foreground="{DynamicResource TextSecondary}"/>
                                    <TextBlock Text="Auditoria" VerticalAlignment="Center" FontWeight="Medium" Classes="Secondary"/>
                                </StackPanel>
                            </Button>
                        </ListBox>
                    </StackPanel>

                    <!-- Footer -->
                    <StackPanel Grid.Row="2" Margin="12,0,12,30">
                        <Button Command="{Binding NavigateToSettingsCommand}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0" CornerRadius="8" Padding="12,10">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <material:MaterialIcon Kind="SettingsOutline" Width="22" Height="22" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Text="Configuraes" VerticalAlignment="Center" FontWeight="Medium" Classes="Secondary"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </SplitView.Pane>

            <!-- Main Content Area -->
            <Grid>
                <TransitioningContentControl Content="{Binding CurrentPage}" Margin="0">
                    <TransitioningContentControl.PageTransition>
                        <PageSlide Duration="0:0:0.4" Orientation="Vertical" />
                    </TransitioningContentControl.PageTransition>
                </TransitioningContentControl>
            </Grid>
        </SplitView>

        <!-- Custom Draggable Area (TitleBar) - GARANTIDO NO TOPO -->
        <Border Name="DragArea" Height="45" VerticalAlignment="Top" Background="#00000000" IsHitTestVisible="True" />
    </Panel>
</Window>

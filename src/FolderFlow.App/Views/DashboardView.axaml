<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="FolderFlow.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    
    <ScrollViewer>
        <StackPanel Margin="10" Spacing="25">
            <!-- Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="Painel Principal" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <TextBlock Text="Resumo em tempo real da saúde do seu sistema" FontSize="14" Foreground="Gray"/>
            </StackPanel>
            
            <!-- Cards de Estatísticas Superiores -->
            <UniformGrid Columns="3" Rows="1">
                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="FileCheck" Width="24" Height="24" Foreground="#10B981"/>
                            <TextBlock Text="Processados" FontSize="14" FontWeight="SemiBold" Foreground="Gray" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalFilesProcessed}" FontSize="36" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="AlertCircle" Width="24" Height="24" Foreground="#EF4444"/>
                            <TextBlock Text="Erros Detectados" FontSize="14" FontWeight="SemiBold" Foreground="Gray" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalErrors}" FontSize="36" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}" BorderThickness="1" CornerRadius="12" Padding="20" Margin="10">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <material:MaterialIcon Kind="Sync" Width="24" Height="24" Foreground="#3B82F6"/>
                            <TextBlock Text="Jobs Ativos" FontSize="14" FontWeight="SemiBold" Foreground="Gray" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveWatchers}" FontSize="36" FontWeight="Bold" Foreground="#3B82F6"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Atividade Recente -->
            <Grid ColumnDefinitions="*, 350" Margin="10,0">
                <StackPanel Grid.Column="0" Spacing="15">
                    <TextBlock Text="Atividade Recente" FontSize="18" FontWeight="SemiBold"/>
                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="12" Padding="10" MinHeight="200">
                        <ListBox ItemsSource="{Binding RecentActivity}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="10" Margin="5">
                                        <material:MaterialIcon Kind="History" Foreground="Gray" Width="16" Height="16"/>
                                        <TextBlock Text="{Binding}" FontSize="13"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Border>
                </StackPanel>

                <!-- Status do Processador -->
                <StackPanel Grid.Column="1" Margin="20,0,0,0" Spacing="15">
                    <TextBlock Text="Auditoria de Saúde" FontSize="18" FontWeight="SemiBold"/>
                    <Border Background="{DynamicResource SystemControlBackgroundAltHighBrush}" CornerRadius="12" Padding="20">
                        <StackPanel Spacing="15">
                            <StackPanel Orientation="Horizontal" Spacing="15">
                                <material:MaterialIcon Kind="Memory" Width="24" Height="24" Foreground="#8B5CF6"/>
                                <StackPanel>
                                    <TextBlock Text="Fila de Execução" FontSize="12" Foreground="Gray"/>
                                    <TextBlock Text="{Binding CurrentlyRunning, StringFormat='{}{0} Job(s) em background'}" FontSize="14" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <Separator/>
                            <TextBlock Text="Todas as automações estão respondendo corretamente." FontSize="12" TextWrapping="Wrap" Foreground="Gray"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
            
        </StackPanel>
    </ScrollViewer>
</UserControl>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FolderFlow.App.ViewModels"
             xmlns:material="using:Material.Icons.Avalonia"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1000" d:DesignHeight="750"
             x:Class="FolderFlow.App.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">
    <ScrollViewer>
        <StackPanel Margin="20" Spacing="30">
            <!-- Header -->
            <StackPanel Spacing="5">
                <TextBlock Text="Resumo do Sistema" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                <TextBlock Text="Visão geral do desempenho e saúde da sua automação" FontSize="14" Foreground="{DynamicResource TextSecondary}"/>
            </StackPanel>

            <!-- Status Cards (Premium) -->
            <UniformGrid Columns="4" Rows="1">
                <!-- Card: Jobs Ativos -->
                <Border Margin="0,0,15,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20" BoxShadow="{DynamicResource PremiumShadow}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <material:MaterialIcon Kind="FileTree" Width="26" Height="26" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Jobs Totais" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalJobs}" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Card: Watch Folders -->
                <Border Margin="0,0,15,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20" BoxShadow="{DynamicResource PremiumShadow}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <material:MaterialIcon Kind="EyeRefresh" Width="26" Height="26" Foreground="{DynamicResource SuccessColor}"/>
                            <TextBlock Text="Hotfolders" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveWatchers}" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Card: Processados -->
                <Border Margin="0,0,15,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20" BoxShadow="{DynamicResource PremiumShadow}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <material:MaterialIcon Kind="CheckCircleOutline" Width="26" Height="26" Foreground="{DynamicResource AccentColor}"/>
                            <TextBlock Text="Arquivos Sinc." FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalFilesProcessed}" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>

                <!-- Card: Erros -->
                <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20" BoxShadow="{DynamicResource PremiumShadow}">
                    <StackPanel Spacing="10">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <material:MaterialIcon Kind="AlertCircleOutline" Width="26" Height="26" Foreground="{DynamicResource DangerColor}"/>
                            <TextBlock Text="Erros" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding TotalErrors}" FontSize="36" FontWeight="ExtraBold" Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Seção de Atividade Recente e Performance -->
            <Grid ColumnDefinitions="*, 350">
                <!-- Gráfico ou Lista Grande de Atividade -->
                <Border Grid.Column="0" Margin="0,0,25,0" Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
                    <Grid RowDefinitions="Auto, *">
                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="15" Margin="0,0,0,20">
                            <material:MaterialIcon Kind="LightningBolt" Width="22" Height="22" Foreground="{DynamicResource WarningColor}"/>
                            <TextBlock Text="Logs em Tempo Real" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                        </StackPanel>
                        
                        <ListBox Grid.Row="1" ItemsSource="{Binding RecentActivity}" Background="Transparent" BorderThickness="0">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,10" Padding="12" Background="{DynamicResource ButtonHoverBackground}" CornerRadius="8">
                                        <Grid ColumnDefinitions="Auto, *">
                                            <material:MaterialIcon Grid.Column="0" Kind="History" Width="18" Height="18" Foreground="{DynamicResource AccentColor}" Margin="0,0,15,0"/>
                                            <TextBlock Grid.Column="1" Text="{Binding}" FontSize="13" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>

                <!-- Status Atual do Motor de Execução -->
                <StackPanel Grid.Column="1" Spacing="20">
                    <Border Background="{DynamicResource CardBackground}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="16" Padding="20">
                        <StackPanel Spacing="15">
                            <TextBlock Text="Motor FlowEngine" FontSize="18" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/>
                            
                            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" Margin="0,10,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Instâncias Ativas" Foreground="{DynamicResource TextSecondary}"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CurrentlyRunning}" FontWeight="Bold" Foreground="{DynamicResource AccentColor}"/>
                                
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Uso de Banda (Estimado)" Foreground="{DynamicResource TextSecondary}" Margin="0,10,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="12.4 MB/s" FontWeight="Bold" Foreground="{DynamicResource SuccessColor}" Margin="0,10,0,0"/>
                            </Grid>
                            
                            <Separator Background="{DynamicResource CardBorderBrush}" Margin="0,10"/>
                            
                            <Button HorizontalAlignment="Stretch" Classes="accent" CornerRadius="8">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <material:MaterialIcon Kind="Broom"/>
                                    <TextBlock Text="Limpar Cache de Auditoria"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Border>
                    
                    <!-- Banner Premium -->
                    <Border Background="{DynamicResource AccentColor}" CornerRadius="16" Padding="20">
                        <StackPanel Spacing="10">
                            <material:MaterialIcon Kind="StarCircle" Width="30" Height="30" Foreground="White"/>
                            <TextBlock Text="FolderFlow Pro Ativo" FontWeight="Bold" Foreground="White" FontSize="16"/>
                            <TextBlock Text="Acesso total a Cloud Hydration e Hotfolders." Foreground="White" Opacity="0.8" TextWrapping="Wrap" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>